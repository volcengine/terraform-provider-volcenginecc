{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/AllowListType"
  ],
  "definitions": {
    "Instance": {
      "properties": {
        "InstanceId": {
          "description": "Instance ID",
          "type": "string"
        },
        "InstanceName": {
          "description": "Instance Name",
          "type": "string"
        },
        "VPC": {
          "description": "VPC ID of the instance",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "RocketMQ Access Allowlist",
  "handlers": {
    "create": {
      "permissions": [
        "RocketMQ:CreateAllowList",
        "RocketMQ:DescribeAllowLists",
        "RocketMQ:AssociateAllowList",
        "RocketMQ:DescribeAllowListDetail"
      ]
    },
    "delete": {
      "permissions": [
        "RocketMQ:DescribeAllowListDetail",
        "RocketMQ:DeleteAllowList",
        "RocketMQ:DisassociateAllowList"
      ]
    },
    "list": {
      "permissions": [
        "RocketMQ:DescribeAllowLists"
      ]
    },
    "read": {
      "permissions": [
        "RocketMQ:DescribeAllowLists",
        "RocketMQ:DescribeAllowListDetail"
      ]
    },
    "update": {
      "permissions": [
        "RocketMQ:DescribeAllowListDetail",
        "RocketMQ:ModifyAllowList",
        "RocketMQ:AssociateAllowList",
        "RocketMQ:DisassociateAllowList"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/AllowListId"
  ],
  "properties": {
    "AllowList": {
      "description": "IP allowlist. Separate multiple IP addresses with commas (,) and do not repeat addresses",
      "type": "string"
    },
    "AllowListCategory": {
      "description": "Allowlist Category",
      "type": "string"
    },
    "AllowListDesc": {
      "description": "Allowlist Description",
      "semantic": "description",
      "type": "string"
    },
    "AllowListIPNum": {
      "description": "Total number of IP addresses (or address ranges) in the allowlist",
      "format": "int64",
      "type": "integer"
    },
    "AllowListId": {
      "description": "Allowlist ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "AllowListName": {
      "description": "Allowlist Name",
      "semantic": "resourceName",
      "type": "string"
    },
    "AllowListType": {
      "description": "IP address type in the allowlist. Only IPv4 is supported",
      "type": "string"
    },
    "AssociatedInstanceNum": {
      "description": "Total number of instances bound to the allowlist",
      "format": "int64",
      "type": "integer"
    },
    "AssociatedInstances": {
      "description": "Bound Instance List",
      "insertionOrder": true,
      "items": {
        "$ref": "#/definitions/Instance"
      },
      "type": "array",
      "uniqueItems": true
    },
    "InstanceId": {
      "description": "Instance ID",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AllowListId",
    "/properties/AllowListIPNum",
    "/properties/AssociatedInstanceNum",
    "/properties/AssociatedInstances/*/InstanceName",
    "/properties/AssociatedInstances/*/VPC"
  ],
  "required": [
    "AllowListName"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::RocketMQ::AllowList"
}