{
  "additionalProperties": false,
  "definitions": {
    "RecordSet": {
      "properties": {
        "FQDN": {
          "description": "Full domain name",
          "type": "string"
        },
        "Host": {
          "description": "Subdomain prefix",
          "type": "string"
        },
        "ID": {
          "description": "Record set ID",
          "type": "string"
        },
        "Line": {
          "description": "Resolution line",
          "type": "string"
        },
        "Type": {
          "description": "Record type",
          "type": "string"
        },
        "WeightEnabled": {
          "description": "Load balancing enabled",
          "type": "boolean"
        }
      },
      "type": "object"
    }
  },
  "description": "A DNS record maps a domain name to resource information within a VPC.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/Host",
      "/properties/Line",
      "/properties/RecordId",
      "/properties/Type",
      "/properties/Value",
      "/properties/ZID"
    ],
    "required": [
      "/properties/ZID"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "private_zone:CreateRecord",
        "private_zone:UpdateRecord",
        "private_zone:QueryRecord"
      ]
    },
    "delete": {
      "permissions": [
        "private_zone:DeleteRecord",
        "private_zone:QueryRecord"
      ]
    },
    "list": {
      "permissions": [
        "private_zone:ListRecords"
      ]
    },
    "read": {
      "permissions": [
        "private_zone:QueryRecord",
        "private_zone:ListRecordSets"
      ]
    },
    "update": {
      "permissions": [
        "private_zone:UpdateRecord",
        "private_zone:QueryRecord",
        "private_zone:UpdateRecordSet",
        "private_zone:ListRecordSets"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/RecordId"
  ],
  "properties": {
    "CreatedAt": {
      "description": "Creation time of the DNS record.",
      "semantic": "createdTime",
      "type": "string"
    },
    "Enable": {
      "description": "Indicates whether the DNS record is enabled.",
      "type": "boolean"
    },
    "Host": {
      "description": "Domain prefix for the subdomain.",
      "type": "string"
    },
    "LastOperator": {
      "description": "Account ID of the most recent update to the DNS record.",
      "type": "string"
    },
    "Line": {
      "description": "DNS record route, only the default route 'default' is supported.",
      "type": "string"
    },
    "RecordId": {
      "description": "DNS record ID.",
      "semantic": "resourceId",
      "type": "string"
    },
    "RecordSets": {
      "description": "Record set list",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/RecordSet"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Remark": {
      "description": "Remarks. Supports UTF-8 characters. Maximum 16 characters. Default is an empty string.",
      "semantic": "description",
      "type": "string"
    },
    "TTL": {
      "description": "DNS record TTL (time to live), in seconds. Default is 600.",
      "type": "integer"
    },
    "Type": {
      "description": "DNS record type. Valid values are: A: A record. AAAA: AAAA record. CNAME: CNAME record. TXT: TXT record. MX: MX record. PTR: PTR record. A: A record. AAAA: AAAA record. CNAME: CNAME record. TXT: TXT record. MX: MX record. PTR: PTR record.",
      "type": "string"
    },
    "UpdatedAt": {
      "description": "Last update time of the DNS record.",
      "semantic": "updatedTime",
      "type": "string"
    },
    "Value": {
      "description": "Record value.",
      "type": "string"
    },
    "Weight": {
      "description": "Record weight. The weight takes effect only when load balancing is enabled for the domain name.",
      "type": "integer"
    },
    "WeightEnabled": {
      "description": "Indicates whether load balancing is enabled for this record set.",
      "type": "boolean"
    },
    "ZID": {
      "description": "Domain name ID.",
      "type": "integer"
    }
  },
  "readOnlyProperties": [
    "/properties/RecordId",
    "/properties/CreatedAt",
    "/properties/UpdatedAt",
    "/properties/LastOperator",
    "/properties/RecordSets"
  ],
  "required": [
    "Host",
    "Type",
    "Value",
    "ZID"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::PrivateZone::Record",
  "writeOnlyProperties": [
    "/properties/WeightEnabled"
  ]
}