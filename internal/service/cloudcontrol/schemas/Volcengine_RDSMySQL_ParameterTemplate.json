{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/TemplateType",
    "/properties/ProjectName",
    "/properties/TemplateTypeVersion",
    "/properties/EngineType"
  ],
  "definitions": {
    "InstanceParam": {
      "description": "Instance parameter",
      "properties": {
        "DefaultValue": {
          "description": "Default value of the parameter",
          "type": "string"
        },
        "Description": {
          "description": "Parameter description",
          "type": "string"
        },
        "ExpectValue": {
          "description": "Expected value of the parameter",
          "type": "string"
        },
        "Name": {
          "description": "Instance parameter name",
          "type": "string"
        },
        "Restart": {
          "description": "Whether a restart is required for the instance to take effect",
          "type": "boolean"
        },
        "RunningValue": {
          "description": "Parameter runtime value",
          "type": "string"
        },
        "ValueRange": {
          "description": "Parameter value range",
          "type": "string"
        }
      },
      "required": [
        "Name",
        "RunningValue"
      ],
      "type": "object"
    }
  },
  "description": "Volcano Engine Cloud Database MySQL version parameter template for managing and applying MySQL instance parameter configurations in bulk",
  "filterProperties": {
    "filterableProperties": [
      "/properties/TemplateName",
      "/properties/TemplateCategory",
      "/properties/TemplateType",
      "/properties/ProjectName",
      "/properties/TemplateTypeVersion",
      "/properties/TemplateSource",
      "/properties/EngineType"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "rds_mysql:CreateParameterTemplate",
        "rds_mysql:DescribeParameterTemplate"
      ]
    },
    "delete": {
      "permissions": [
        "rds_mysql:DeleteParameterTemplate",
        "rds_mysql:DescribeParameterTemplate"
      ]
    },
    "list": {
      "permissions": [
        "rds_mysql:ListParameterTemplates"
      ]
    },
    "read": {
      "permissions": [
        "rds_mysql:DescribeParameterTemplate"
      ]
    },
    "update": {
      "permissions": [
        "rds_mysql:ModifyParameterTemplate",
        "rds_mysql:DescribeParameterTemplate"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/TemplateId"
  ],
  "properties": {
    "AccountId": {
      "description": "Account ID",
      "type": "string"
    },
    "CreateTime": {
      "description": "Creation time (UTC+8), format: yyyy-MM-dd HH:mm:ss",
      "semantic": "createdTime",
      "type": "string"
    },
    "EngineType": {
      "description": "Database engine type. Values: InnoDB (InnoDB engine), RocksDB (RocksDB engine). Default: InnoDB",
      "type": "string"
    },
    "NeedRestart": {
      "description": "Whether the template contains parameters that require a restart",
      "type": "boolean"
    },
    "ParameterNum": {
      "description": "Number of parameters included in the template",
      "format": "int64",
      "type": "integer"
    },
    "ProjectName": {
      "description": "Associated project",
      "semantic": "projectName",
      "type": "string"
    },
    "TemplateCategory": {
      "description": "Template category. Value: DBEngine (database engine parameter)",
      "type": "string"
    },
    "TemplateDesc": {
      "description": "Parameter template description",
      "semantic": "description",
      "type": "string"
    },
    "TemplateId": {
      "description": "Parameter template ID, automatically generated by the system",
      "semantic": "resourceId",
      "type": "string"
    },
    "TemplateName": {
      "description": "Parameter template name",
      "semantic": "resourceName",
      "type": "string"
    },
    "TemplateParams": {
      "description": "Parameters included in the parameter template",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/InstanceParam"
      },
      "type": "array",
      "uniqueItems": true
    },
    "TemplateSource": {
      "description": "Parameter template type. Values: System (system template), User (user template)",
      "type": "string"
    },
    "TemplateType": {
      "description": "Database type of the parameter template. Default: Mysql",
      "type": "string"
    },
    "TemplateTypeVersion": {
      "description": "Database version of the parameter template. Value range: MySQL_5_7 (MySQL 5.7 version), MySQL_8_0 (MySQL 8.0 version)",
      "type": "string"
    },
    "UpdateTime": {
      "description": "Template modification time",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/TemplateId",
    "/properties/AccountId",
    "/properties/CreateTime",
    "/properties/UpdateTime",
    "/properties/NeedRestart",
    "/properties/ParameterNum",
    "/properties/TemplateParams/*/DefaultValue",
    "/properties/TemplateParams/*/Description",
    "/properties/TemplateParams/*/ExpectValue",
    "/properties/TemplateParams/*/Restart",
    "/properties/TemplateParams/*/ValueRange",
    "/properties/TemplateCategory",
    "/properties/TemplateSource"
  ],
  "required": [
    "TemplateName",
    "TemplateParams"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::RDSMySQL::ParameterTemplate"
}