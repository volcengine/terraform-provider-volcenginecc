        "Name": {
          "description": "Tag or annotation key",
          "type": "string"
        },
        "Value": {
          "description": "Tag or annotation value. If set to empty, the key will be deleted",
          "type": "string"
        }
      },
      "required": [
        "Name"
      ],
      "type": "object"
    }
  },
