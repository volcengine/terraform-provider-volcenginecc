{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/Type"
  ],
  "definitions": {
    "AlertingRuleLevel": {
      "description": "Alert severity configuration",
      "properties": {
        "Comparator": {
          "description": "Alert rule comparison condition. Options: \u003e, \u003e=, \u003c, \u003c=, ==, !=",
          "type": "string"
        },
        "For": {
          "description": "Alert duration. Possible values: 0s, 1m, 2m, 5m, 10m",
          "type": "string"
        },
        "Level": {
          "description": "Alert rule severity. Currently supports P0, P1, or P2",
          "type": "string"
        },
        "Threshold": {
          "description": "Alert rule threshold",
          "type": "number"
        }
      },
      "required": [
        "Level",
        "For",
        "Comparator"
      ],
      "type": "object"
    },
    "AlertingRuleQuery": {
      "description": "Alert query configuration",
      "properties": {
        "PromQL": {
          "description": "Query statement",
          "type": "string"
        },
        "WorkspaceId": {
          "description": "Workspace ID",
          "type": "string"
        }
      },
      "required": [
        "WorkspaceId"
      ],
      "type": "object"
    },
    "TagsObj": {
      "description": "Tag/annotation key-value pair configuration",
      "properties": {
        "Key": {
          "description": "Tag or annotation key",
          "type": "string"
        },
        "Value": {
          "description": "Tag or annotation value. If set to empty, the key will be deleted",
          "type": "string"
        }
      },
      "type": "object"
    },
    "TemplateKV": {
      "description": "Tag/annotation key-value pair configuration",
