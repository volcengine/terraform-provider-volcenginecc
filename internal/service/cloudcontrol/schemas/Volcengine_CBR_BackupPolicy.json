{
  "additionalProperties": false,
  "description": "The backup policy defines information such as backup cycle and backup type. Subsequently, backup plans associate the backup policy with backup storage space to achieve automatic backup",
  "filterProperties": {
    "filterableProperties": [
      "/properties/EnablePolicy",
      "/properties/Name",
      "/properties/PolicyId"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "cbr:CreateBackupPolicy",
        "cbr:DescribeBackupPolicies"
      ]
    },
    "delete": {
      "permissions": [
        "cbr:DeleteBackupPolicy",
        "cbr:DescribeBackupPolicies"
      ]
    },
    "list": {
      "permissions": [
        "cbr:DescribeBackupPolicies"
      ]
    },
    "read": {
      "permissions": [
        "cbr:DescribeBackupPolicies"
      ]
    },
    "update": {
      "permissions": [
        "cbr:UpdateBackupPolicy",
        "cbr:DescribeBackupPolicies"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/PolicyId"
  ],
  "properties": {
    "AccountId": {
      "description": "Account ID that created this policy",
      "type": "string"
    },
    "BackupType": {
      "description": "Backup type. Values are as follows: FULL: full backup; INCREMENTAL: incremental backup",
      "enum": [
        "FULL",
        "INCREMENTAL"
      ],
      "type": "string"
    },
    "CreatedTime": {
      "description": "Creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Crontab": {
      "description": "Backup cycle, using a crontab expression",
      "type": "string"
    },
    "EnablePolicy": {
      "description": "Whether the policy is enabled. Values are as follows: true: policy enabled; false: policy disabled",
      "type": "boolean"
    },
    "Name": {
      "description": "Policy Name",
      "semantic": "resourceName",
      "type": "string"
    },
    "PlanNumber": {
      "description": "Number of backup plans associated with this policy",
      "type": "integer"
    },
    "PolicyId": {
      "description": "Backup Policy ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "RetentionDay": {
      "description": "Restore point retention period. -1 means retain indefinitely. Other valid values range from [1, 999999]",
      "type": "integer"
    },
    "RetentionNumMax": {
      "description": "Maximum number of restore points retained",
      "type": "integer"
    },
    "RetentionNumMin": {
      "description": "Minimum restore point retention limit",
      "type": "integer"
    },
    "UpdatedTime": {
      "description": "Update time",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/PolicyId",
    "/properties/AccountId",
    "/properties/CreatedTime",
    "/properties/PlanNumber",
    "/properties/UpdatedTime"
  ],
  "required": [
    "BackupType",
    "Crontab",
    "EnablePolicy",
    "Name",
    "RetentionDay",
    "RetentionNumMax",
    "RetentionNumMin"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::CBR::BackupPolicy",
  "writeOnlyProperties": [
    "/properties/RetentionNumMax",
    "/properties/RetentionNumMin"
  ]
}