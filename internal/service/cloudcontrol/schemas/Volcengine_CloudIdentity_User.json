{
  "additionalProperties": false,
  "description": "Cloud Identity Center users are mapped one-to-one with enterprise employee identities. A Cloud Identity Center user is an identity type that can be uniquely linked to an IAM user under an account for single sign-on. Cloud Identity Center provides full lifecycle management and permission management for enterprise employee identities. We recommend that you centrally manage employee identities within this product.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/Source",
      "/properties/UserName"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "cloudidentity:CreateUser",
        "cloudidentity:ResetPassword",
        "cloudidentity:GetUser"
      ]
    },
    "delete": {
      "permissions": [
        "cloudidentity:DeleteUser",
        "cloudidentity:GetUser"
      ]
    },
    "list": {
      "permissions": [
        "cloudidentity:ListUsers"
      ]
    },
    "read": {
      "permissions": [
        "cloudidentity:GetUser"
      ]
    },
    "update": {
      "permissions": [
        "cloudidentity:UpdateUser",
        "cloudidentity:ResetPassword",
        "cloudidentity:GetUser"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/UserId"
  ],
  "properties": {
    "CreatedTime": {
      "description": "Creation Time.",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "User Description.",
      "semantic": "description",
      "type": "string"
    },
    "DisplayName": {
      "description": "User Display Name.",
      "type": "string"
    },
    "Email": {
      "description": "Email.",
      "type": "string"
    },
    "IdentityType": {
      "description": "Identity Type.",
      "type": "string"
    },
    "Password": {
      "description": "Password. Password must be 8–32 characters long and include at least three of the following: uppercase letters, lowercase letters, numbers, and special symbols.",
      "type": "string"
    },
    "PasswordResetRequired": {
      "description": "Is password reset required on first login?",
      "type": "boolean"
    },
    "Phone": {
      "description": "Mobile Number.",
      "type": "string"
    },
    "Source": {
      "description": "User Source.",
      "type": "string"
    },
    "UpdatedTime": {
      "description": "Update Time.",
      "semantic": "updatedTime",
      "type": "string"
    },
    "UserId": {
      "description": "User ID.",
      "semantic": "resourceId",
      "type": "string"
    },
    "UserName": {
      "description": "Username.",
      "semantic": "resourceName",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/CreatedTime",
    "/properties/UpdatedTime",
    "/properties/IdentityType",
    "/properties/Source",
    "/properties/UserId"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::CloudIdentity::User",
  "writeOnlyProperties": [
    "/properties/Password",
    "/properties/PasswordResetRequired"
  ]
}