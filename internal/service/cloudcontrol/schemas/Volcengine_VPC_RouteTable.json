{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ProjectName",
    "/properties/AssociateType",
    "/properties/VpcId"
  ],
  "definitions": {
    "DescribeRouteEntry": {
      "properties": {
        "Description": {
          "description": "Route Entry Description",
          "maxLength": 255,
          "type": "string"
        },
        "DestinationCidrBlock": {
          "description": "Destination CIDR of the route entry",
          "type": "string"
        },
        "DestinationPrefixListId": {
          "description": "Prefix List ID",
          "type": "string"
        },
        "NextHopId": {
          "description": "Next Hop Resource ID",
          "type": "string"
        },
        "NextHopName": {
          "description": "Name of the next hop resource for the route entry",
          "type": "string"
        },
        "NextHopType": {
          "description": "Next hop type for custom route entry. 1. Instance: ECS instance 2. HaVip: High availability virtual IP 3. NetworkInterface: Secondary network interface 4. NatGW: NAT gateway 5. VpnGW: VPN gateway 6. TransitRouter: Transit router 7. IPv6GW: IPv6 gateway 8. CloudConnector: Cloud connector 9. GWLBEndpoint: Gateway load balancer endpoint",
          "type": "string"
        },
        "PrefixListCidrBlocks": {
          "description": "Prefix List CIDR",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "RouteEntryId": {
          "description": "Route Entry ID",
          "type": "string"
        },
        "RouteEntryName": {
          "description": "Route Entry Name",
          "type": "string"
        },
        "RouteTableId": {
          "description": "Route Table ID",
          "type": "string"
        },
        "Status": {
          "description": "Route entry status. 1. Pending: Pending creation 2. Available: Available",
          "type": "string"
        },
        "Type": {
          "description": "Route entry type. 1. Custom: Custom route entry 2. System: System default route entry",
          "enum": [
            "Custom",
            "System"
          ],
          "type": "string"
        },
        "VpcId": {
          "description": "ID of the private network to which the route entry belongs",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Tag": {
      "properties": {
        "Key": {
          "description": "User tag key",
          "type": "string"
        },
        "Value": {
          "description": "User tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "A route table consists of a series of route entries that specify the next hop cloud resource for private network traffic. Each subnet must be associated with only one route table, allowing resources within the subnet to forward traffic via the route table",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/AssociateType",
      "/properties/RouteTableId",
      "/properties/RouteTableName",
      "/properties/VpcId",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "vpc:CreateRouteTable",
        "vpc:CreateRouteEntry",
        "vpc:AssociateRouteTable",
        "vpc:DescribeRouteTableList",
        "vpc:DescribeRouteEntryList",
        "vpc:DisassociateRouteTable"
      ]
    },
    "delete": {
      "permissions": [
        "vpc:DeleteRouteTable",
        "vpc:DeleteRouteEntry",
        "vpc:DisassociateRouteTable",
        "vpc:DescribeRouteTableList",
        "vpc:DescribeRouteEntryList"
      ]
    },
    "list": {
      "permissions": [
        "vpc:DescribeRouteTableList"
      ]
    },
    "read": {
      "permissions": [
        "vpc:DescribeRouteTableList",
        "vpc:DescribeRouteEntryList"
      ]
    },
    "update": {
      "permissions": [
        "vpc:ModifyRouteTableAttributes",
        "vpc:DisassociateRouteTable",
        "vpc:AssociateRouteTable",
        "vpc:DeleteRouteEntry",
        "vpc:CreateRouteEntry",
        "vpc:ModifyRouteEntry",
        "vpc:UntagResources",
        "vpc:TagResources",
        "vpc:DescribeRouteTableList",
        "vpc:DescribeRouteEntryList"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/RouteTableId"
  ],
  "properties": {
    "AccountId": {
      "description": "Account ID owning the route table",
      "type": "string"
    },
    "AssociateType": {
      "description": "Association type for route table creation input. 1. Subnet: Subnet association 2. Gateway: Gateway association",
      "enum": [
        "Subnet",
        "Gateway"
      ],
      "type": "string"
    },
    "CreatedTime": {
      "description": "Route Table Creation Time",
      "semantic": "createdTime",
      "type": "string"
    },
    "CustomRouteEntries": {
      "description": "List of custom route entries associated with the route table",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/DescribeRouteEntry"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Description": {
      "description": "Route Table Description",
      "maxLength": 255,
      "semantic": "description",
      "type": "string"
    },
    "Ipv4GatewayId": {
      "description": "IPv4 Gateway ID associated with the route table",
      "type": "string"
    },
    "Ipv6GatewayId": {
      "description": "IPv6 Gateway ID associated with the route table",
      "type": "string"
    },
    "ProjectName": {
      "default": "default",
      "description": "Name of the project owning the route table",
      "semantic": "projectName",
      "type": "string"
    },
    "RouteTableId": {
      "description": "Route Table ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "RouteTableName": {
      "description": "Route Table Name",
      "maxLength": 128,
      "minLength": 1,
      "semantic": "resourceName",
      "type": "string"
    },
    "RouteTableType": {
      "description": "Route table type. 1. Custom: Custom route table 2. System: System route table",
      "enum": [
        "Custom",
        "System"
      ],
      "type": "string"
    },
    "SubnetIds": {
      "description": "List of associated subnet IDs",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "SystemRouteEntries": {
      "description": "List of system default route entries associated with the route table",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/DescribeRouteEntry"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Tags": {
      "description": "Tag List",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "UpdatedTime": {
      "description": "Route Table Last Updated Time",
      "semantic": "updatedTime",
      "type": "string"
    },
    "VpcId": {
      "description": "ID of the VPC owning the route table",
      "type": "string"
    },
    "VpcName": {
      "description": "VPC Name",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AccountId",
    "/properties/RouteTableId",
    "/properties/RouteTableType",
    "/properties/UpdatedTime",
    "/properties/CreatedTime",
    "/properties/VpcName",
    "/properties/SystemRouteEntries",
    "/properties/CustomRouteEntries/*/RouteEntryId",
    "/properties/CustomRouteEntries/*/PrefixListCidrBlocks",
    "/properties/CustomRouteEntries/*/RouteTableId",
    "/properties/CustomRouteEntries/*/Status",
    "/properties/CustomRouteEntries/*/Type",
    "/properties/CustomRouteEntries/*/VpcId"
  ],
  "required": [
    "VpcId"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::VPC::RouteTable"
}