{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/FileSystemId"
  ],
  "description": "A snapshot is a backup method. Each snapshot is a backup of file storage at a specific point in time. If data is lost or a failure occurs, you can use snapshots to restore file storage and recover lost data",
  "filterProperties": {
    "filterableProperties": [
      "/properties/FileSystemId",
      "/properties/SnapshotId",
      "/properties/SnapshotName",
      "/properties/SnapshotType",
      "/properties/Status"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "FileNAS:CreateSnapshot",
        "FileNAS:DescribeSnapshots"
      ]
    },
    "delete": {
      "permissions": [
        "FileNAS:DeleteSnapshot",
        "FileNAS:DescribeSnapshots"
      ]
    },
    "list": {
      "permissions": [
        "FileNAS:DescribeSnapshots"
      ]
    },
    "read": {
      "permissions": [
        "FileNAS:DescribeSnapshots"
      ]
    },
    "update": {
      "permissions": [
        "FileNAS:UpdateSnapshot",
        "FileNAS:DescribeSnapshots"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/SnapshotId"
  ],
  "properties": {
    "CreatedTime": {
      "description": "Snapshot Creation Time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Snapshot Description",
      "semantic": "description",
      "type": "string"
    },
    "FileSystemId": {
      "description": "File System ID",
      "type": "string"
    },
    "FileSystemName": {
      "description": "File System Name",
      "type": "string"
    },
    "IsEncrypt": {
      "description": "Is encryption enabled. Currently only false is supported (not encrypted)",
      "type": "boolean"
    },
    "Progress": {
      "description": "Snapshot Creation Progress",
      "type": "string"
    },
    "RetentionDays": {
      "default": 2147483647,
      "description": "Snapshot Retention Period. Default is 2147483647 (permanent retention)",
      "type": "integer"
    },
    "SnapshotId": {
      "description": "Snapshot ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "SnapshotName": {
      "description": "Snapshot Name",
      "semantic": "resourceName",
      "type": "string"
    },
    "SnapshotType": {
      "default": "Manual",
      "description": "Snapshot Type. Default is Manual (manual snapshot)",
      "enum": [
        "Manual"
      ],
      "type": "string"
    },
    "SourceSize": {
      "description": "File System Capacity (GiB)",
      "type": "integer"
    },
    "SourceVersion": {
      "description": "File System Version",
      "type": "string"
    },
    "Status": {
      "description": "Snapshot Status. Details: Progressing: Creating. Accomplished: Created successfully. Failed: Creation failed",
      "enum": [
        "Progressing",
        "Accomplished",
        "Failed"
      ],
      "semantic": "status",
      "type": "string"
    },
    "ZoneId": {
      "description": "Availability Zone ID",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/CreatedTime",
    "/properties/FileSystemName",
    "/properties/Progress",
    "/properties/RetentionDays",
    "/properties/SnapshotId",
    "/properties/SnapshotType",
    "/properties/SourceSize",
    "/properties/SourceVersion",
    "/properties/Status",
    "/properties/ZoneId",
    "/properties/IsEncrypt"
  ],
  "required": [
    "FileSystemId",
    "SnapshotName"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::FileNAS::Snapshot"
}