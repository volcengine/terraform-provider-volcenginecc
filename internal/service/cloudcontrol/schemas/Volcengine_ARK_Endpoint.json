{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ProjectName",
    "/properties/ModelUnitId",
    "/properties/ModelReference",
    "/properties/Name",
    "/properties/Description",
    "/properties/Tags",
    "/properties/RateLimit",
    "/properties/Moderation"
  ],
  "definitions": {
    "Certificate": {
      "description": "Endpoint inference application layer encryption certificate",
      "properties": {
        "NotAfter": {
          "description": "X509 private certificate expiration time, represented as a timestamp in seconds",
          "format": "int64",
          "type": "integer"
        },
        "NotBefore": {
          "description": "X509 private certificate activation time, represented as a timestamp in seconds",
          "format": "int64",
          "type": "integer"
        },
        "PCAHost": {
          "description": "Certificate subject",
          "type": "string"
        },
        "PCAInstanceCertificate": {
          "description": "PEM format leaf certificate",
          "type": "string"
        },
        "PCAName": {
          "description": "Certificate name",
          "type": "string"
        },
        "PCARootCACertificate": {
          "description": "PEM format root certificate",
          "type": "string"
        },
        "PCASubCACertificate": {
          "description": "Intermediate certificate and root certificate in PEM format",
          "type": "string"
        }
      },
      "type": "object"
    },
    "FoundationModel": {
      "description": "Base model",
      "properties": {
        "ModelVersion": {
          "description": "Base model version",
          "type": "string"
        },
        "Name": {
          "description": "Base model name. Note: Model names are lowercase. The model name format for doubao 1.5 generation models is \"doubao-1-5-**\".",
          "type": "string"
        }
      },
      "type": "object"
    },
    "ModelReference": {
      "description": "Endpoint access model",
      "properties": {
        "CustomModelId": {
          "description": "Custom model ID",
          "type": "string"
        },
        "FoundationModel": {
          "$ref": "#/definitions/FoundationModel",
          "description": "Base model",
          "type": "object"
        }
      },
      "type": "object"
    },
    "Moderation": {
      "description": "Content guardrail scheme",
      "properties": {
        "Strategy": {
          "description": "Content safety guardrail scheme. Values: Default: default scheme. Lower latency, broadly covers general content safety requirements; Basic: basic scheme (public beta). Supports providing triggered risk categories in interface responses, currently only includes two risk types: severe violations and aggressive behavior. Note: If using streaming interface calls, this scheme is not recommended, as it will increase the length of each output fragment and raise latency",
          "type": "string"
        }
      },
      "type": "object"
    },
    "RateLimit": {
      "description": "Endpoint rate limiting",
      "properties": {
        "Rpm": {
          "description": "Requests Per Minute, number of requests per minute",
          "format": "int32",
          "type": "integer"
        },
        "Tpm": {
          "description": "Tokens Per Minute, number of tokens requested per minute",
          "format": "int32",
          "type": "integer"
        }
      },
      "type": "object"
    },
    "Tag": {
      "properties": {
        "Key": {
          "description": "Tag key",
          "type": "string"
        },
        "Value": {
          "description": "Tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "When using large language models for inference services, the inference endpoint is the key entry point for model invocation. Developers can initiate API/SDK inference requests to the large model simply by specifying the ID, enabling quick access and flexible invocation. The system provides a unified API invocation method, call monitoring, rate limiting strategies, and security mechanisms to ensure stability and security during inference",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/ModelReference/CustomModelId",
      "/properties/ModelReference/FoundationModel/Name",
      "/properties/ModelReference/FoundationModel/ModelVersion",
      "/properties/EndpointModelType",
      "/properties/EndpointId",
      "/properties/Name",
      "/properties/Status",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "ark:CreateEndpoint",
        "ark:GetEndpoint",
        "ark:GetEndpointCertificate"
      ]
    },
    "delete": {
      "permissions": [
        "ark:GetEndpoint",
        "ark:DeleteEndpoint",
        "ark:StopEndpoint"
      ]
    },
    "list": {
      "permissions": [
        "ark:ListEndpoints"
      ]
    },
    "read": {
      "permissions": [
        "ark:GetEndpoint",
        "ark:GetEndpointCertificate"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/EndpointId"
  ],
  "properties": {
    "BatchOnly": {
      "description": "Whether only BatchChat is supported. If true, only batch inference interfaces can be accessed; otherwise, only online inference interfaces can be accessed",
      "type": "boolean"
    },
    "Certificate": {
      "$ref": "#/definitions/Certificate",
      "description": "Certificate information",
      "type": "object"
    },
    "CreateTime": {
      "description": "Endpoint creation time, RFC3339 format",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Endpoint description",
      "semantic": "description",
      "type": "string"
    },
    "EndpointId": {
      "description": "Inference access point ID.",
      "semantic": "resourceId",
      "type": "string"
    },
    "EndpointModelType": {
      "description": "Access point model type. Options: FoundationModel for base model; CustomModel for custom model.",
      "enum": [
        "FoundationModel",
        "CustomModel"
      ],
      "type": "string"
    },
    "ModelReference": {
      "$ref": "#/definitions/ModelReference",
      "description": "Endpoint access model",
      "type": "object"
    },
    "ModelUnitId": {
      "description": "Model unit. If empty, indicates postpaid; otherwise, prepaid.",
      "type": "string"
    },
    "Moderation": {
      "$ref": "#/definitions/Moderation",
      "description": "Content guardrail scheme",
      "type": "object"
    },
    "Name": {
      "description": "Endpoint name",
      "semantic": "resourceName",
      "type": "string"
    },
    "ProjectName": {
      "default": "default",
      "description": "Project name the resource belongs to; default value is \"default\"",
      "semantic": "projectName",
      "type": "string"
    },
    "RateLimit": {
      "$ref": "#/definitions/RateLimit",
      "description": "Endpoint rate limiting",
      "type": "object"
    },
    "RollingId": {
      "description": "Endpoint switch ID",
      "type": "string"
    },
    "ScaleTierId": {
      "description": "If a TPM protection package exists, this is the TPM protection package ID.",
      "type": "string"
    },
    "Status": {
      "description": "Endpoint status",
      "semantic": "status",
      "type": "string"
    },
    "StatusReason": {
      "description": "Additional status information",
      "type": "string"
    },
    "SupportRolling": {
      "description": "Whether endpoint supports switching model versions",
      "type": "boolean"
    },
    "SupportScaleTier": {
      "description": "Whether TPM protection package is supported",
      "type": "boolean"
    },
    "Tags": {
      "description": "Tags bound to the endpoint",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "UpdateTime": {
      "description": "Endpoint update time, RFC3339 format",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/EndpointId",
    "/properties/BatchOnly",
    "/properties/EndpointModelType",
    "/properties/Status",
    "/properties/StatusReason",
    "/properties/SupportRolling",
    "/properties/RollingId",
    "/properties/ScaleTierId",
    "/properties/SupportScaleTier",
    "/properties/Certificate",
    "/properties/CreateTime",
    "/properties/UpdateTime"
  ],
  "required": [
    "Name",
    "ModelReference"
  ],
  "tagging": {
    "tagOnCreate": true,
    "taggable": true
  },
  "typeName": "Volcengine::ARK::Endpoint"
}