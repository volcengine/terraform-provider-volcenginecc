    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "dns:CreateUserZoneBackup",
        "dns:ListUserZoneBackups"
      ]
    },
    "delete": {
      "permissions": [
        "dns:DeleteUserZoneBackup",
        "dns:ListUserZoneBackups"
      ]
    },
    "list": {
      "permissions": [
        "dns:ListUserZoneBackups"
      ]
    },
    "read": {
      "permissions": [
        "dns:ListUserZoneBackups"
      ]
    }
  },
  "primaryIdentifier": [
