{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/PublicKey",
    "/properties/PrivateKey",
    "/properties/ProjectName",
    "/properties/CertificateType"
  ],
  "definitions": {
    "Tag": {
      "properties": {
        "Key": {
          "description": "User tag key",
          "type": "string"
        },
        "Value": {
          "description": "User tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "ALB supports uploading server certificates and CA certificates to the console and manages uploaded certificates separately",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/CertificateId",
      "/properties/CertificateType",
      "/properties/CertificateName",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "alb:UploadCertificate",
        "alb:UploadCACertificate",
        "alb:DescribeAllCertificates"
      ]
    },
    "delete": {
      "permissions": [
        "alb:DescribeAllCertificates",
        "alb:DeleteCertificate",
        "alb:DeleteCACertificate"
      ]
    },
    "list": {
      "permissions": [
        "alb:DescribeAllCertificates"
      ]
    },
    "read": {
      "permissions": [
        "alb:DescribeCertificates",
        "alb:DescribeCACertificates"
      ]
    },
    "update": {
      "permissions": [
        "alb:DescribeAllCertificates",
        "alb:ModifyCertificateAttributes",
        "alb:ModifyCACertificateAttributes",
        "alb:UntagResources",
        "alb:TagResources"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/CertificateId",
    "/properties/CertificateType"
  ],
  "properties": {
    "CertificateId": {
      "description": "Certificate ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "CertificateName": {
      "description": "Certificate name. Length must be between 1 and 128 characters, start with a letter or Chinese character, and may include numbers, periods (.), underscores (_), and hyphens (-)",
      "maxLength": 128,
      "minLength": 1,
      "semantic": "resourceName",
      "type": "string"
    },
    "CertificateType": {
      "description": "Certificate type. Options: CA: CA certificate; Server: server certificate",
      "enum": [
        "CA",
        "Server"
      ],
      "type": "string"
    },
    "CreatedTime": {
      "description": "Certificate creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Certificate description",
      "semantic": "description",
      "type": "string"
    },
    "DomainName": {
      "description": "Certificate domain name",
      "type": "string"
    },
    "ExpiredAt": {
      "description": "Certificate expiration time",
      "type": "string"
    },
    "Listeners": {
      "description": "List of listeners associated with the certificate",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "PrivateKey": {
      "description": "Server certificate private key. Required when certificate type is Server",
      "type": "string"
    },
    "ProjectName": {
      "description": "Project name",
      "semantic": "projectName",
      "type": "string"
    },
    "PublicKey": {
      "description": "Server certificate public key",
      "type": "string"
    },
    "San": {
      "description": "Certificate subject alternative name list. Use English ',' to separate multiple domain names. Includes (commonName, DnsName, IP)",
      "type": "string"
    },
    "Status": {
      "description": "Certificate status. Options: Creating: creating; Active: active; Deleting: deleting",
      "semantic": "status",
      "type": "string"
    },
    "Tags": {
      "description": "Tag list",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    }
  },
  "readOnlyProperties": [
    "/properties/CertificateId",
    "/properties/CreatedTime",
    "/properties/DomainName",
    "/properties/ExpiredAt",
    "/properties/Listeners",
    "/properties/San",
    "/properties/Status"
  ],
  "required": [
    "CertificateType",
    "PublicKey"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::ALB::Certificate",
  "writeOnlyProperties": [
    "/properties/PublicKey",
    "/properties/PrivateKey"
  ]
}