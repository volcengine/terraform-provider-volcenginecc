{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ChargeInfo/AutoRenew",
    "/properties/ChargeInfo/ChargeType",
    "/properties/ChargeInfo/PeriodUnit",
    "/properties/ChargeInfo/Period",
    "/properties/EipId",
    "/properties/UserName",
    "/properties/UserPassword",
    "/properties/StorageType",
    "/properties/IpWhiteList",
    "/properties/SubnetId",
    "/properties/Version",
    "/properties/ZoneId",
    "/properties/ProjectName",
    "/properties/VpcId"
  ],
  "definitions": {
    "ChargeInfo": {
      "properties": {
        "AutoRenew": {
          "description": "包年包月实例到期后是否自动续费，true-自动续费 false(默认)-不自动续费,到期实例关停。",
          "type": "boolean"
        },
        "ChargeExpireTime": {
          "description": "包年包月实例的到期时间。",
          "type": "string"
        },
        "ChargeStartTime": {
          "description": "实例的计费开始时间。",
          "type": "string"
        },
        "ChargeStatus": {
          "description": "实例的计费状态，支持的类型包括:  Normal-正常, Overdue-按量计费欠费, Expired-包年包月到期",
          "enum": [
            "Normal",
            "Overdue",
            "Expired"
          ],
          "type": "string"
        },
        "ChargeType": {
          "description": "实例的计费类型，支持的类型包括: PostPaid-按量付费, PrePaid-包年包月。",
          "enum": [
            "PostPaid",
            "PrePaid"
          ],
          "type": "string"
        },
        "OverdueReclaimTime": {
          "description": "实例欠费关停后的预计释放时间。",
          "type": "string"
        },
        "OverdueTime": {
          "description": "实例的欠费关停时间。",
          "type": "string"
        },
        "Period": {
          "description": "包年包月类型实例的购买时长。",
          "type": "integer"
        },
        "PeriodUnit": {
          "description": "包年包月类型实例的生命周期单位，即指定以月（Month/Monthly）或以年（Year/Yearly）为单位购买。",
          "enum": [
            "Month",
            "Year",
            "Monthly",
            "Yearly",
            ""
          ],
          "type": "string"
        }
      },
      "required": [
        "ChargeType"
      ],
      "type": "object"
    },
    "ConnectionInfo": {
      "properties": {
        "EndpointType": {
          "description": "实例的接入点类型。PLAINTEXT：默认接入点。SASL_PLAINTEXT：SASL接入点（私网）。SASL_SSL：SASL接入点（公网）。未开启公网访问时，不提供此接入点。",
          "type": "string"
        },
        "InternalEndpoint": {
          "description": "实例私网访问域名。",
          "type": "string"
        },
        "NetworkType": {
          "description": "接入点的网络类型。统一为 PrivateNetwork。",
          "type": "string"
        },
        "PublicEndpoint": {
          "description": "实例公网访问域名。",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Tag": {
      "properties": {
        "Key": {
          "description": "标签的键。",
          "type": "string"
        },
        "Value": {
          "description": "标签的值。",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "消息队列 Kafka版是一款基于 Apache Kafka 构建的分布式消息中间件服务，具备高吞吐、高可扩展性等特性，提供流式数据的发布/订阅和多副本存储机制，广泛应用于日志压缩收集、流式数据处理、消息解耦、流量削峰去谷等应用场景。",
  "filterProperties": {
    "filterableProperties": [
      "/properties/InstanceId",
      "/properties/InstanceName",
      "/properties/InstanceStatus",
      "/properties/ProjectName",
      "/properties/ZoneId",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "Kafka:CreateInstance",
        "Kafka:DescribeInstances",
        "Kafka:AddTagsToResource",
        "Kafka:DescribeInstanceDetail",
        "Kafka:DescribeTopics"
      ]
    },
    "delete": {
      "permissions": [
        "Kafka:DeleteInstance",
        "Kafka:DescribeInstanceDetail"
      ]
    },
    "list": {
      "permissions": [
        "Kafka:DescribeInstances"
      ]
    },
    "read": {
      "permissions": [
        "Kafka:DescribeInstanceDetail",
        "Kafka:DescribeTopics"
      ]
    },
    "update": {
      "permissions": [
        "Kafka:ModifyInstanceAttributes",
        "Kafka:RemoveTagsFromResource",
        "Kafka:AddTagsToResource",
        "Kafka:ModifyInstanceSpec",
        "Kafka:DescribeInstances",
        "Kafka:ModifyInstanceParameters",
        "Kafka:DescribeInstanceDetail",
        "Kafka:DescribeTopics"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/InstanceId"
  ],
  "properties": {
    "AccountId": {
      "description": "创建实例的主账号 ID。",
      "type": "string"
    },
    "ChargeInfo": {
      "$ref": "#/definitions/ChargeInfo",
      "description": "Kafka 实例的计费类型等计费信息。",
      "type": "object"
    },
    "ComputeSpec": {
      "description": "实例的计算规格。",
      "type": "string"
    },
    "ConnectionInfo": {
      "description": "Kafka 实例的连接信息。",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/ConnectionInfo"
      },
      "type": "array",
      "uniqueItems": true
    },
    "CreatedTime": {
      "description": "实例的创建时间，时间显示格式为 YYYY-MM-DD'T'HH:MM:SS'Z'。",
      "semantic": "createdTime",
      "type": "string"
    },
    "EipId": {
      "description": "EIP 的 ID。",
      "type": "string"
    },
    "InstanceDescription": {
      "description": "Kafka 实例的简单描述。长度范围为 1~128 个字符。",
      "maxLength": 128,
      "semantic": "description",
      "type": "string"
    },
    "InstanceId": {
      "description": "Kafka 实例的 ID。",
      "semantic": "resourceId",
      "type": "string"
    },
    "InstanceName": {
      "description": "Kafka 实例的名称。只能包含中文、字母、数字、下划线（_）和连字符（-）。不能以数字和连字符（-）开头。长度范围为 1~128 个字符。",
      "maxLength": 128,
      "minLength": 1,
      "semantic": "resourceName",
      "type": "string"
    },
    "InstanceStatus": {
      "description": "Kafka 实例的状态。Error：错误, Deleting：删除中, Creating：部署中, Upgrading：升级中, Updating：变更中, Running：运行中, Scaling：更配中, Rebuilding：重建中, Destroying：销毁中, Restarting：重启中, Migrating：迁移中, Restoring：恢复中, Importing：导入中, NetCreating：申请公网中, NetReleasing：释放公网中, Rollingback：回滚中, CreateFailed：创建失败, UpgradeFailed：升级失败, ScaleFailed：更配失败, RestartFailed：重启失败",
      "semantic": "status",
      "type": "string"
    },
    "IpWhiteList": {
      "description": "实例绑定的白名单 ID 列表。绑定白名单后，仅配置在白名单中的 IP 地址与地址段才能访问此实例。若未设置此参数，新 Kafka 实例将绑定白名单 default，对应 IP 地址为 0.0.0.0，表示允许所有地址访问该 Kafka 实例。",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "NeedRebalance": {
      "description": "是否开启再均衡。",
      "type": "boolean"
    },
    "Parameters": {
      "description": "Kafka 实例的初始参数配置,格式为json,参数列表: 最大消息大小(MessageMaxByte)1-12MB 默认10, 消息保留时间(LogRetentionHours)0-2160Hour 默认72, 消费位点保留时长(OffsetRetentionMinutes)1-10080Min 默认4320 消息时间类型(MessageTimestampType)LogAppendTime/CreateTime 消息写入到服务端时间、producer创建消息时间。",
      "type": "string"
    },
    "PartitionNumber": {
      "description": "分区数量。",
      "type": "integer"
    },
    "PrivateDomainOnPublic": {
      "description": "是否开启公网解析。",
      "type": "boolean"
    },
    "ProjectName": {
      "description": "当前创建的 Kafka 实例所属的 IAM 项目。",
      "semantic": "projectName",
      "type": "string"
    },
    "StorageSpace": {
      "description": "实例的存储空间，单位为 GiB, 必须指定为 100 的倍数。",
      "type": "integer"
    },
    "StorageType": {
      "default": "ESSD_FlexPL",
      "description": "Kafka 实例数据存储的云盘类型。可设置为 ESSD_FlexPL 或 ESSD_PL0，默认为 ESSD_FlexPL。",
      "enum": [
        "ESSD_FlexPL",
        "ESSD_PL0"
      ],
      "type": "string"
    },
    "SubnetId": {
      "description": "实例所在的 VPC 子网 ID。",
      "type": "string"
    },
    "Tags": {
      "description": "云资源标签。可以将实例通过标签进行归类，便于实例的搜索和资源聚合。",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "Topics": {
      "description": "一个 Kafka 实例下的 Topic 列表",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "UsableGroupNumber": {
      "description": "当前实例剩余可用消费组个数。",
      "type": "integer"
    },
    "UsablePartitionNumber": {
      "description": "当前实例剩余可用分区数。",
      "type": "integer"
    },
    "UsedGroupNumber": {
      "description": "当前实例已经创建的消费组(Group)个数。",
      "type": "integer"
    },
    "UsedPartitionNumber": {
      "description": "当前实例已经使用的分区个数。",
      "type": "integer"
    },
    "UsedStorageSpace": {
      "description": "实例已用储空间，单位为 GiB。",
      "type": "integer"
    },
    "UsedTopicNumber": {
      "description": "当前实例已创建的 Topic 个数。",
      "type": "integer"
    },
    "UserName": {
      "description": "SASL/PLAIN 用户名称，需要满足以下要求: 1.由小写字母、数字、连字符（-）或下划线组成。2.长度为 3~64 个字符。3.用户名不支持设置为 admin 或 monitor,且实例内用户名称唯一。",
      "maxLength": 64,
      "minLength": 3,
      "type": "string"
    },
    "UserPassword": {
      "description": "SASL/PLAIN 用户的密码，需要满足以下要求: 1.长度在8到32个字符 2.由大写字母、小写字母、数字、特殊字符中的任意三种组成 3.支持的特殊字符包括 !@#$%^\u0026*()_+-=。",
      "maxLength": 32,
      "minLength": 8,
      "type": "string"
    },
    "Version": {
      "description": "支持的 Kafka 版本，当前支持的版本包括 2.2.2, 2.8.2。",
      "type": "string"
    },
    "VpcId": {
      "description": "实例所在的私有网络 (VPC) ID。",
      "type": "string"
    },
    "ZoneId": {
      "description": "实例所在的可用区 ID。消息队列 Kafka版实例支持跨 AZ 部署, 多个可用区ID之间以逗号间隔。",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/InstanceId",
    "/properties/InstanceStatus",
    "/properties/UsedTopicNumber",
    "/properties/UsedGroupNumber",
    "/properties/UsableGroupNumber",
    "/properties/UsedPartitionNumber",
    "/properties/UsablePartitionNumber",
    "/properties/UsedStorageSpace",
    "/properties/PrivateDomainOnPublic",
    "/properties/CreatedTime",
    "/properties/ConnectionInfo",
    "/properties/AccountId",
    "/properties/ChargeInfo/ChargeStatus",
    "/properties/ChargeInfo/ChargeExpireTime",
    "/properties/ChargeInfo/OverdueTime",
    "/properties/ChargeInfo/OverdueReclaimTime",
    "/properties/ChargeInfo/ChargeStartTime",
    "/properties/Topics"
  ],
  "required": [
    "Version",
    "ZoneId",
    "SubnetId",
    "VpcId",
    "ComputeSpec"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::Kafka::Instance",
  "writeOnlyProperties": [
    "/properties/NeedRebalance",
    "/properties/PartitionNumber",
    "/properties/IpWhiteList",
    "/properties/UserName",
    "/properties/UserPassword",
    "/properties/ChargeInfo/AutoRenew"
  ]
}