{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/TaskType",
    "/properties/SourceTopicID",
    "/properties/ProcessStartTime",
    "/properties/ProcessEndTime"
  ],
  "definitions": {
    "RequestCycle": {
      "properties": {
        "CronTab": {
          "description": "Cron 表达式，最小粒度为分钟，24 小时制。例如 0 18 * * * 表示每天 18 点整执行一次。",
          "type": "string"
        },
        "CronTimeZone": {
          "description": "设置 Type 为 Cron 时，还需设置时区。",
          "type": "string"
        },
        "Time": {
          "description": "调度的周期或者定期执行的时间点（距离 00:00 的分钟数），取值范围为 1~1440，单位为分钟。",
          "type": "integer"
        },
        "Type": {
          "description": "调度周期类型。可选值：Period、Fixed、Cron。",
          "type": "string"
        }
      },
      "required": [
        "Type",
        "Time"
      ],
      "type": "object"
    }
  },
  "description": "定时 SQL 分析任务的资源定义。",
  "filterProperties": {
    "filterableProperties": [
      "/properties/TaskId",
      "/properties/TaskName",
      "/properties/Status",
      "/properties/SourceTopicID",
      "/properties/SourceProjectID",
      "/properties/SourceProjectName",
      "/properties/SourceTopicName"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "TLS:CreateScheduleSqlTask",
        "TLS:DescribeScheduleSqlTask"
      ]
    },
    "delete": {
      "permissions": [
        "TLS:DeleteScheduleSqlTask",
        "TLS:DescribeScheduleSqlTask"
      ]
    },
    "list": {
      "permissions": [
        "TLS:DescribeScheduleSqlTasks"
      ]
    },
    "read": {
      "permissions": [
        "TLS:DescribeScheduleSqlTask"
      ]
    },
    "update": {
      "permissions": [
        "TLS:ModifyScheduleSqlTask",
        "TLS:DescribeScheduleSqlTask",
        "TLS:AddTagsToResource",
        "TLS:RemoveTagsFromResource"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/TaskId"
  ],
  "properties": {
    "CreatedTime": {
      "description": "创建时间（秒级 Unix 时间戳）。",
      "format": "int64",
      "semantic": "createdTime",
      "type": "integer"
    },
    "Description": {
      "description": "定时 SQL 分析任务的简单描述。不支持\u003c\u003e、'、\\、\\\\。长度范围为 0～64 个字符。",
      "maxLength": 64,
      "semantic": "description",
      "type": "string"
    },
    "DestProjectID": {
      "description": "目标日志项目 ID。",
      "type": "string"
    },
    "DestRegion": {
      "description": "目标日志主题所属地域。默认为当前地域。",
      "type": "string"
    },
    "DestTopicID": {
      "description": "用于存储定时 SQL 分析结果数据的目标日志主题 ID。",
      "type": "string"
    },
    "DestTopicName": {
      "description": "目标日志主题名称。",
      "type": "string"
    },
    "ProcessEndTime": {
      "description": "调度定时 SQL 分析任务的结束时间，格式为秒级时间戳。如果不配置，表示持续运行定时 SQL 分析任务。到达结束时间后，日志服务不会再创建实例及执行定时 SQL 分析，但任务状态仍为运行中，直至手动暂停任务。",
      "format": "int64",
      "type": "integer"
    },
    "ProcessSqlDelay": {
      "description": "每次调度的延迟时间。取值范围为 0～120，单位为秒。如果不配置，则表示 0，即无延时。",
      "maximum": 120,
      "type": "integer"
    },
    "ProcessStartTime": {
      "description": "调度定时 SQL 分析任务的开始时间，即创建第一个实例的时间。格式为秒级时间戳。",
      "format": "int64",
      "type": "integer"
    },
    "ProcessTimeWindow": {
      "description": "SQL 时间窗口，即定时 SQL 分析任务运行时，日志检索与分析的时间范围，左闭右开格式。最大为 24 小时，最小为 1 分钟。",
      "type": "string"
    },
    "Query": {
      "description": "定时 SQL 分析任务定期执行的检索与分析语句，应符合日志服务的检索与分析语法。",
      "type": "string"
    },
    "RequestCycle": {
      "$ref": "#/definitions/RequestCycle",
      "description": "定时 SQL 分析任务的调度周期。调度周期决定每个实例的调度时间。建议调度周期不小于 SQL 时间窗口。"
    },
    "SourceProjectID": {
      "description": "源日志项目 ID。",
      "type": "string"
    },
    "SourceProjectName": {
      "description": "源日志项目名称。",
      "type": "string"
    },
    "SourceTopicID": {
      "description": "待进行定时 SQL 分析的原始日志所在的日志主题 ID。仅支持当前地域的日志主题。",
      "type": "string"
    },
    "SourceTopicName": {
      "description": "源日志主题名称。",
      "type": "string"
    },
    "Status": {
      "description": "完成任务配置后是否立即启动定时 SQL 分析任务。可选值：0 关闭；1 立即启动。",
      "semantic": "status",
      "type": "integer"
    },
    "TaskId": {
      "description": "任务 ID。",
      "semantic": "resourceId",
      "type": "string"
    },
    "TaskName": {
      "description": "定时 SQL 分析任务名称。命名规则请参考资源命名规则。",
      "semantic": "resourceName",
      "type": "string"
    },
    "TaskType": {
      "description": "任务类型：0 表示日志到日志；1 表示日志到指标。",
      "type": "integer"
    },
    "UpdatedTime": {
      "description": "修改时间（秒级 Unix 时间戳）。",
      "format": "int64",
      "semantic": "updatedTime",
      "type": "integer"
    }
  },
  "readOnlyProperties": [
    "/properties/TaskId",
    "/properties/CreatedTime",
    "/properties/UpdatedTime",
    "/properties/SourceProjectID",
    "/properties/SourceProjectName",
    "/properties/DestProjectID",
    "/properties/SourceTopicName",
    "/properties/DestTopicName"
  ],
  "required": [
    "TaskName",
    "TaskType",
    "SourceTopicID",
    "DestTopicID",
    "ProcessStartTime",
    "ProcessTimeWindow",
    "Query",
    "RequestCycle",
    "Status"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::TLS::ScheduleSqlTask",
  "writeOnlyProperties": [
    "/properties/TaskType"
  ]
}