{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ChargeType",
    "/properties/InstanceType",
    "/properties/PerformanceDensity",
    "/properties/ProjectName",
    "/properties/ZoneId"
  ],
  "definitions": {
    "ChargeConfig": {
      "description": "File system billing configuration.",
      "properties": {
        "ChargeStatus": {
          "description": "Billing status. Value description: WaitingPaid: Waiting for payment, Pending: Creating, Modifying: Reconfiguring, Failed: Failed, Normal: Normal, Expired: Expired, Overdue: Overdue, Reclaimed: Reclaimed, Terminated: Unsubscribed.",
          "type": "string"
        },
        "ChargeType": {
          "description": "Billing type. Only supports PayAsYouGo, which means pay-as-you-go billing.",
          "type": "string"
        },
        "ExpireTime": {
          "description": "Expiration time.",
          "type": "string"
        },
        "ReclaimTime": {
          "description": "Recycle time.",
          "type": "string"
        },
        "StopTime": {
          "description": "Shutdown time.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Performance": {
      "description": "File system performance information.",
      "properties": {
        "BandwidthMode": {
          "description": "Bandwidth mode. Value description: Baseline: Baseline bandwidth mode, Provisioned: Provisioned bandwidth mode.",
          "type": "string"
        },
        "BaselineBandwidth": {
          "description": "Baseline bandwidth.",
          "format": "int32",
          "type": "integer"
        },
        "BaselineIops": {
          "description": "Baseline IOPS.",
          "format": "int32",
          "type": "integer"
        },
        "BurstBandwidth": {
          "description": "Burst bandwidth.",
          "format": "int32",
          "type": "integer"
        },
        "BurstIops": {
          "description": "Burst IOPS.",
          "format": "int32",
          "type": "integer"
        },
        "ProvisionedBandwidth": {
          "description": "Provisioned bandwidth.",
          "format": "int32",
          "type": "integer"
        },
        "ProvisionedIops": {
          "description": "Provisioned IOPS.",
          "format": "int32",
          "type": "integer"
        }
      },
      "required": [
        "BandwidthMode"
      ],
      "type": "object"
    },
    "Storage": {
      "description": "File system capacity information.",
      "properties": {
        "CapacityLimit": {
          "description": "Capacity limit, in MiB.",
          "format": "int64",
          "type": "integer"
        },
        "CapacityUsed": {
          "description": "Used capacity, in MiB.",
          "format": "int64",
          "type": "integer"
        },
        "InodeLimit": {
          "description": "File count limit.",
          "format": "int64",
          "type": "integer"
        },
        "InodeUsed": {
          "description": "Used file count.",
          "format": "int64",
          "type": "integer"
        }
      },
      "type": "object"
    },
    "Tag": {
      "description": "Tag key-value pair.",
      "properties": {
        "Key": {
          "description": "Tag key.",
          "type": "string"
        },
        "Type": {
          "description": "Tag type. Value description: System: System tag, Custom: Custom tag.",
          "type": "string"
        },
        "Value": {
          "description": "Tag value.",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "A file system is a storage system that manages files through a directory tree structure. It is divided into local file systems and remote file systems. This refers specifically to remote file systems, which support concurrent access by multiple compute nodes and shared datasets.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ChargeType",
      "/properties/FileSystemId",
      "/properties/FileSystemName",
      "/properties/InstanceType",
      "/properties/Performance/BandwidthMode",
      "/properties/PerformanceDensity",
      "/properties/ProjectName",
      "/properties/Status",
      "/properties/ZoneId",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "efs:CreateFileSystem",
        "efs:DescribeFileSystems"
      ]
    },
    "delete": {
      "permissions": [
        "efs:DeleteFileSystem",
        "efs:DescribeFileSystems"
      ]
    },
    "list": {
      "permissions": [
        "efs:DescribeFileSystems"
      ]
    },
    "read": {
      "permissions": [
        "efs:DescribeFileSystems"
      ]
    },
    "update": {
      "permissions": [
        "efs:UpdateFileSystem",
        "efs:UntagResources",
        "efs:TagResources",
        "efs:DescribeFileSystems"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/FileSystemId"
  ],
  "properties": {
    "AccessPointLimit": {
      "description": "Access point limit.",
      "format": "int32",
      "type": "integer"
    },
    "ChargeConfig": {
      "$ref": "#/definitions/ChargeConfig",
      "description": "File system billing configuration.",
      "type": "object"
    },
    "ChargeType": {
      "description": "Billing type. Only supports PayAsYouGo, which means pay-as-you-go billing.",
      "type": "string"
    },
    "CreateTime": {
      "description": "File system creation time.",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Description.",
      "type": "string"
    },
    "DowngradeUnlockTime": {
      "description": "Time when file system bandwidth can be downgraded.",
      "type": "string"
    },
    "FileSystemId": {
      "description": "File system ID.",
      "semantic": "resourceId",
      "type": "string"
    },
    "FileSystemName": {
      "description": "File system name.",
      "semantic": "resourceName",
      "type": "string"
    },
    "InstanceType": {
      "description": "Basic: Basic type, Premium: Premium type.",
      "type": "string"
    },
    "MountPointLimit": {
      "description": "Mount point limit.",
      "format": "int32",
      "type": "integer"
    },
    "Performance": {
      "$ref": "#/definitions/Performance",
      "description": "File system performance information.",
      "type": "object"
    },
    "PerformanceDensity": {
      "description": "File system performance density. Value description: Basic_50: Basic type 50MB/s/TiB, Premium_125: Premium type 125MB/s/TiB.",
      "type": "string"
    },
    "ProjectName": {
      "description": "Project name.",
      "semantic": "projectName",
      "type": "string"
    },
    "ProtocolTypes": {
      "description": "Protocol type.",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Status": {
      "description": "File system status. Value description: Creating: Creating. CreateError: Creation failed. Running: Running. Updating: Updating. Deleting: Deleting. DeleteError: Deletion failed. Deleted: Deleted. Stopped: Stopped.",
      "semantic": "status",
      "type": "string"
    },
    "Storage": {
      "$ref": "#/definitions/Storage",
      "description": "File system capacity information.",
      "type": "object"
    },
    "Tags": {
      "description": "Tag list.",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "UpdateTime": {
      "description": "File system update time.",
      "semantic": "updatedTime",
      "type": "string"
    },
    "ZoneId": {
      "description": "Availability zone ID.",
      "type": "string"
    },
    "ZoneName": {
      "description": "Availability zone name.",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AccessPointLimit",
    "/properties/ChargeConfig",
    "/properties/CreateTime",
    "/properties/DowngradeUnlockTime",
    "/properties/FileSystemId",
    "/properties/MountPointLimit",
    "/properties/Performance/BaselineBandwidth",
    "/properties/Performance/BaselineIops",
    "/properties/Performance/BurstIops",
    "/properties/Performance/ProvisionedIops",
    "/properties/ProtocolTypes",
    "/properties/Status",
    "/properties/Storage",
    "/properties/UpdateTime",
    "/properties/ZoneName"
  ],
  "required": [
    "Performance",
    "FileSystemName",
    "InstanceType",
    "PerformanceDensity",
    "ZoneId"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::EFS::FileSystem",
  "writeOnlyProperties": [
    "/properties/ChargeType"
  ]
