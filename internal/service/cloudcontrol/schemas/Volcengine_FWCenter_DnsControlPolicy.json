{
  "additionalProperties": false,
  "definitions": {
    "AddressInfo": {
      "properties": {
        "Address": {
          "description": "Specific address information.",
          "type": "string"
        },
        "Description": {
          "description": "Description information.",
          "type": "string"
        },
        "Type": {
          "description": "Address type. Supported values are as follows. ip: IPv4 address; ipv6: IPv6 address; domain: domain name; port: port number.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "SourceInfo": {
      "properties": {
        "Region": {
          "description": "VPC region information.",
          "type": "string"
        },
        "VpcId": {
          "description": "VPC ID。",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "Domain denylist access control policy.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/Description",
      "/properties/Destination",
      "/properties/InternetFirewallId",
      "/properties/RuleId",
      "/properties/Sources/*/VpcId",
      "/properties/Status"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "fw_center:AddDnsControlPolicy",
        "fw_center:DescribeDnsControlPolicy"
      ]
    },
    "delete": {
      "permissions": [
        "fw_center:DeleteDnsControlPolicy",
        "fw_center:DescribeDnsControlPolicy"
      ]
    },
    "list": {
      "permissions": [
        "fw_center:DescribeDnsControlPolicy"
      ]
    },
    "read": {
      "permissions": [
        "fw_center:DescribeDnsControlPolicy"
      ]
    },
    "update": {
      "permissions": [
        "fw_center:ModifyDnsControlPolicy",
        "fw_center:DescribeDnsControlPolicy"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/RuleId"
  ],
  "properties": {
    "AccountId": {
      "description": "User's unique identifier.",
      "type": "string"
    },
    "Description": {
      "description": "Policy description information.",
      "semantic": "description",
      "type": "string"
    },
    "Destination": {
      "description": "Access target, which can be the unique identifier of a domain or domain address book. Currently, only one address book is supported.",
      "type": "string"
    },
    "DestinationGroupList": {
      "description": "Domain address book name list.",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "DestinationType": {
      "description": "Type of access target. domain: domain; group: domain address book.",
      "enum": [
        "domain",
        "group"
      ],
      "type": "string"
    },
    "DomainList": {
      "description": "Domain list.",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "DomainListV1": {
      "description": "Domain list in the domain address book.",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/AddressInfo"
      },
      "type": "array",
      "uniqueItems": true
    },
    "HitCnt": {
      "description": "Hit count, indicating the number of times the domain denylist access control policy was triggered.",
      "type": "integer"
    },
    "InternetFirewallId": {
      "description": "Internet border firewall instance ID.",
      "type": "string"
    },
    "LastHitTime": {
      "description": "Latest hit timestamp, indicating the last time the domain denylist access control policy was triggered.",
      "type": "integer"
    },
    "RuleId": {
      "description": "Unique identifier of the access control policy.",
      "semantic": "resourceId",
      "type": "string"
    },
    "Sources": {
      "description": "Access source information, including VPC list.",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/SourceInfo"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Status": {
      "description": "Switch status of the domain denylist access control policy. false: Off; true: On.",
      "semantic": "status",
      "type": "boolean"
    },
    "UseCount": {
      "description": "Number of policies occupied by this domain denylist access control policy.",
      "type": "integer"
    }
  },
  "readOnlyProperties": [
    "/properties/HitCnt",
    "/properties/RuleId",
    "/properties/UseCount",
    "/properties/AccountId",
    "/properties/DomainList",
    "/properties/LastHitTime",
    "/properties/DomainListV1",
    "/properties/DestinationGroupList"
  ],
  "required": [
    "Destination",
    "DestinationType"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::FWCenter::DnsControlPolicy",
  "writeOnlyProperties": [
    "/properties/InternetFirewallId"
  ]
}