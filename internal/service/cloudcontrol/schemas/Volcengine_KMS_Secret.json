{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/EncryptionKey",
    "/properties/ExtendedConfig",
    "/properties/ProjectName",
    "/properties/RotationInterval",
    "/properties/SecretName",
    "/properties/SecretType",
    "/properties/SecretValue",
    "/properties/VersionName",
    "/properties/AutomaticRotation"
  ],
  "description": "Credential Manager is a credential management product based on the key management system. It is used to store sensitive credential information required by user business applications, such as AK/SK, account passwords, access keys, database passwords, and certificates. The product provides secure storage, access control, automatic rotation, and auditing capabilities. User business applications can securely and dynamically obtain credential information by integrating the KMS SDK or using the KMS OpenAPI, effectively preventing risks such as information leakage or unintended modification caused by storing sensitive information in plaintext",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/SecretName",
      "/properties/Trn",
      "/properties/SecretType",
      "/properties/SecretState",
      "/properties/Managed",
      "/properties/OwningService",
      "/properties/RotationState",
      "/properties/Description"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "kms:CreateSecret",
        "kms:DescribeSecret"
      ]
    },
    "delete": {
      "permissions": [
        "kms:ScheduleSecretDeletion",
        "kms:DescribeSecret"
      ]
    },
    "list": {
      "permissions": [
        "kms:DescribeSecrets"
      ]
    },
    "read": {
      "permissions": [
        "kms:DescribeSecret"
      ]
    },
    "update": {
      "permissions": [
        "kms:UpdateSecret",
        "kms:DescribeSecret"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/SecretName"
  ],
  "properties": {
    "AutomaticRotation": {
      "description": "Whether to enable automatic rotation. Applies only to credentials of type IAM|RDS|Redis|ECS",
      "type": "boolean"
    },
    "CreatedTime": {
      "description": "Credential creation time",
      "format": "int64",
      "semantic": "createdTime",
      "type": "integer"
    },
    "Description": {
      "description": "Credential description, length: 0 ~ 8192 characters",
      "maxLength": 8192,
      "semantic": "description",
      "type": "string"
    },
    "EncryptionKey": {
      "description": "KMS key TRN for encrypting credential value. If not specified, the default key of Credential Manager is used",
      "type": "string"
    },
    "ExtendedConfig": {
      "description": "Credential extension configuration, used to specify properties for non-Generic credentials",
      "type": "string"
    },
    "LastRotationTime": {
      "description": "Credential last rotation time",
      "type": "string"
    },
    "Managed": {
      "description": "Is managed credential",
      "type": "boolean"
    },
    "OwningService": {
      "description": "Managed Cloud Service",
      "type": "string"
    },
    "ProjectName": {
      "description": "Credential project name. Default value: default",
      "semantic": "projectName",
      "type": "string"
    },
    "RotationInterval": {
      "description": "Automatic rotation interval. Range: 1 ~ 365 days. Format: integer[unit], where integer is the duration and unit is the time unit. Unit value: d (days). For example: 7d means a 7-day interval",
      "type": "string"
    },
    "RotationIntervalRead": {
      "description": "Automatic rotation interval, unit: seconds",
      "type": "integer"
    },
    "RotationState": {
      "description": "Rotation status: Enable: automatic rotation enabled, Disable: automatic rotation disabled, Rotating: automatic rotation in progress, None: automatic rotation not supported",
      "type": "string"
    },
    "ScheduleDeleteTime": {
      "description": "Credential Scheduled Deletion Time",
      "type": "string"
    },
    "ScheduleRotationTime": {
      "description": "Credential next rotation time",
      "type": "string"
    },
    "SecretID": {
      "description": "Credential unique identifier, UUID format",
      "type": "string"
    },
    "SecretName": {
      "description": "Credential name. Valid characters: [a-zA-Z0-9/_+=.@-]",
      "semantic": "resourceId",
      "type": "string"
    },
    "SecretState": {
      "description": "Credential status. Enable: enabled, Disable: disabled, PendingDelete: scheduled for deletion",
      "semantic": "status",
      "type": "string"
    },
    "SecretType": {
      "description": "Credential type. Currently supports Generic|IAM|RDS|Redis|ECS|PGSQL|SQLServer",
      "type": "string"
    },
    "SecretValue": {
      "description": "Credential value. When SecretType is Generic, users can customize it. It is recommended to use JSON key-value pairs",
      "type": "string"
    },
    "Trn": {
      "description": "Credential resource name. Format: trn:kms:${Region}:${AccountID}:secrets/${secret}",
      "type": "string"
    },
    "UID": {
      "description": "Credential tenant ID",
      "type": "string"
    },
    "UpdatedTime": {
      "description": "Credential update date",
      "format": "int64",
      "semantic": "updatedTime",
      "type": "integer"
    },
    "VersionName": {
      "description": "Version alias. Valid characters: [a-zA-Z0-9/_+=.@-]",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/RotationIntervalRead",
    "/properties/CreatedTime",
    "/properties/SecretID",
    "/properties/LastRotationTime",
    "/properties/Managed",
    "/properties/UpdatedTime",
    "/properties/OwningService",
    "/properties/RotationState",
    "/properties/ScheduleDeleteTime",
    "/properties/ScheduleRotationTime",
    "/properties/Trn",
    "/properties/UID",
    "/properties/SecretState"
  ],
  "required": [
    "SecretName",
    "SecretType",
    "SecretValue"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::KMS::Secret",
  "writeOnlyProperties": [
    "/properties/SecretValue",
    "/properties/VersionName",
    "/properties/RotationInterval",
    "/properties/AutomaticRotation"
  ]
}