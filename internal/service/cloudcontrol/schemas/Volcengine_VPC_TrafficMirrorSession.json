{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/NetworkInterfaceId",
    "/properties/Tags",
    "/properties/ProjectName"
  ],
  "definitions": {
    "Tag": {
      "description": "Tag information",
      "properties": {
        "Key": {
          "description": "Tag key",
          "type": "string"
        },
        "Value": {
          "description": "Tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "The mirror session links the mirror source, mirror destination, and filter conditions, enabling private network forwarding of traffic copied from the mirror source to the mirror destination. It serves as the carrier for traffic mirroring",
  "filterProperties": {
    "filterableProperties": [
      "/properties/NetworkInterfaceId",
      "/properties/PacketLength",
      "/properties/Priority",
      "/properties/TrafficMirrorFilterId",
      "/properties/TrafficMirrorSessionId",
      "/properties/TrafficMirrorSessionName",
      "/properties/VirtualNetworkId",
      "/properties/TrafficMirrorTargetId",
      "/properties/ProjectName",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "vpc:CreateTrafficMirrorSession",
        "vpc:DescribeTrafficMirrorSessions"
      ]
    },
    "delete": {
      "permissions": [
        "vpc:DeleteTrafficMirrorSession",
        "vpc:DescribeTrafficMirrorSessions"
      ]
    },
    "list": {
      "permissions": [
        "vpc:DescribeTrafficMirrorSessions"
      ]
    },
    "read": {
      "permissions": [
        "vpc:DescribeTrafficMirrorSessions"
      ]
    },
    "update": {
      "permissions": [
        "vpc:ModifyTrafficMirrorSessionAttributes",
        "vpc:DescribeTrafficMirrorSessions",
        "vpc:TagResources",
        "vpc:UntagResources"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/TrafficMirrorSessionId"
  ],
  "properties": {
    "BusinessStatus": {
      "description": "Session billing status. Normal: Billing in progress. - FinancialLocked: Locked due to overdue payment",
      "type": "string"
    },
    "CreatedTime": {
      "description": "Creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Mirror session instance description",
      "semantic": "description",
      "type": "string"
    },
    "LockReason": {
      "description": "Lock reason",
      "type": "string"
    },
    "NetworkInterfaceId": {
      "description": "Mirror source instance ID. Currently, only ECS primary and secondary network interfaces are supported",
      "type": "string"
    },
    "PacketLength": {
      "description": "Mirror session MTU. Values exceeding this will be truncated. Range: 64–9600",
      "format": "int64",
      "type": "integer"
    },
    "Priority": {
      "description": "Mirror session priority. Range: 1–32766. Priority values must be unique within the same account",
      "format": "int64",
      "type": "integer"
    },
    "ProjectName": {
      "description": "Name of the associated project",
      "semantic": "projectName",
      "type": "string"
    },
    "Status": {
      "description": "Session status",
      "semantic": "status",
      "type": "string"
    },
    "Tags": {
      "description": "Tag information",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "TrafficMirrorFilterId": {
      "description": "Filter condition instance ID",
      "type": "string"
    },
    "TrafficMirrorSessionId": {
      "description": "Mirror session instance ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "TrafficMirrorSessionName": {
      "description": "Mirror session name",
      "semantic": "resourceName",
      "type": "string"
    },
    "TrafficMirrorSourceIds": {
      "description": "Mirror source instance list",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "TrafficMirrorTargetId": {
      "description": "Mirror destination instance ID",
      "type": "string"
    },
    "VirtualNetworkId": {
      "description": "Mirror session VNI. Range: 1–16777215",
      "format": "int64",
      "type": "integer"
    }
  },
  "readOnlyProperties": [
    "/properties/BusinessStatus",
    "/properties/CreatedTime",
    "/properties/LockReason",
    "/properties/Status",
    "/properties/TrafficMirrorSessionId",
    "/properties/TrafficMirrorSourceIds"
  ],
  "required": [
    "NetworkInterfaceId",
    "Priority",
    "TrafficMirrorFilterId",
    "TrafficMirrorTargetId"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::VPC::TrafficMirrorSession",
  "writeOnlyProperties": [
    "/properties/NetworkInterfaceId"
  ]
}