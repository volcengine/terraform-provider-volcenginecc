{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/IsServiceLinkedRole",
    "/properties/RoleName",
    "/properties/ServiceName"
  ],
  "definitions": {
    "Policy": {
      "description": "Role policy",
      "properties": {
        "AttachDate": {
          "description": "Policy binding time.",
          "type": "string"
        },
        "Description": {
          "description": "Policy description.",
          "type": "string"
        },
        "PolicyName": {
          "description": "Policy name",
          "type": "string"
        },
        "PolicyScopes": {
          "description": "Policy authorization scope, specifically refers to the project scope.",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/PolicyScope"
          },
          "type": "array",
          "uniqueItems": true
        },
        "PolicyTrn": {
          "description": "Policy TRN.",
          "type": "string"
        },
        "PolicyType": {
          "description": "Policy type. Policy type. System indicates a system preset policy; Custom indicates a custom policy.",
          "enum": [
            "System",
            "Custom"
          ],
          "type": "string"
        }
      },
      "required": [
        "PolicyName",
        "PolicyType"
      ],
      "type": "object"
    },
    "PolicyScope": {
      "description": "Policy authorization scope, specifically refers to the project scope.",
      "properties": {
        "AttachDate": {
          "description": "Project authorization time.",
          "type": "string"
        },
        "PolicyScopeType": {
          "description": "Authorization type. Global means global authorization (not limited to any project), Project means project-based authorization.",
          "type": "string"
        },
        "ProjectDisplayName": {
          "description": "Project display name for project-based authorization.",
          "type": "string"
        },
        "ProjectName": {
          "description": "Project name for project-based authorization.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Tag": {
      "description": "Tag",
      "properties": {
        "Key": {
          "description": "Tag key",
          "type": "string"
        },
        "Value": {
          "description": "Tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "A role is a virtual identity in the IAM system that grants certain access permissions within an account to various identity entities. Trusted identity entities can assume this role to access cloud resources within the account.",
  "handlers": {
    "create": {
      "permissions": [
        "iam:CreateRole",
        "iam:CreateServiceLinkedRole",
        "iam:GetServiceLinkedRoleTemplate",
        "iam:AttachRolePolicy",
        "iam:GetRole",
        "iam:ListAttachedRolePolicies"
      ]
    },
    "delete": {
      "permissions": [
        "iam:DeleteRole",
        "iam:DeleteServiceLinkedRole",
        "iam:GetRole"
      ]
    },
    "list": {
      "permissions": [
        "iam:ListRoles"
      ]
    },
    "read": {
      "permissions": [
        "iam:GetRole",
        "iam:ListAttachedRolePolicies"
      ]
    },
    "update": {
      "permissions": [
        "iam:UpdateRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:GetRole",
        "iam:ListAttachedRolePolicies",
        "iam:TagResources",
        "iam:UntagResources"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/RoleName"
  ],
  "properties": {
    "CreateDate": {
      "description": "Role creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Role description, maximum length 128",
      "semantic": "description",
      "type": "string"
    },
    "DisplayName": {
      "description": "Role display name, maximum length 64",
      "type": "string"
    },
    "IsServiceLinkedRole": {
      "description": "Service-linked role or not: 0 for No, 1 for Yes",
      "enum": [
        0,
        1
      ],
      "type": "integer"
    },
    "MaxSessionDuration": {
      "default": 43200,
      "description": "Maximum session duration for the role. Maximum session duration for the role. Limits the maximum validity period of temporary security credentials generated by role assumption. Value range: 3600–43200, unit: seconds, default is 43200",
      "maximum": 43200,
      "minimum": 3600,
      "type": "integer"
    },
    "Policies": {
      "description": "Role Strategy",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Policy"
      },
      "type": "array",
      "uniqueItems": true
    },
    "RoleId": {
      "description": "Role ID",
      "semantic": "resourceId",
      "type": "integer"
    },
    "RoleName": {
      "description": "Role name, length 1–64, supports English letters, numbers, and .-_ characters",
      "semantic": "resourceName",
      "type": "string"
    },
    "ServiceName": {
      "description": "Service associated with the service-linked role to be created.",
      "type": "string"
    },
    "Tags": {
      "description": "Tag",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "Trn": {
      "description": "Role TRN",
      "type": "string"
    },
    "TrustPolicyDocument": {
      "description": "Role trust policy. The trust policy follows resource-based policy rules in IAM policy syntax.",
      "type": "string"
    },
    "UpdateDate": {
      "description": "Role update time",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/Trn",
    "/properties/RoleId",
    "/properties/CreateDate",
    "/properties/UpdateDate",
    "/properties/Policies/*/PolicyTrn",
    "/properties/Policies/*/AttachDate",
    "/properties/Policies/*/Description",
    "/properties/Policies/*/PolicyScopes"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::IAM::Role",
  "writeOnlyProperties": [
    "/properties/ServiceName"
  ]
}