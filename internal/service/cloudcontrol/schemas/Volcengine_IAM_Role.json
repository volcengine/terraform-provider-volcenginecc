{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/RoleName"
  ],
  "definitions": {
    "Policy": {
      "description": "Role policy",
      "properties": {
        "PolicyName": {
          "description": "Policy name",
          "type": "string"
        },
        "PolicyType": {
          "description": "Policy type. Policy type. System indicates a system preset policy; Custom indicates a custom policy.",
          "enum": [
            "System",
            "Custom"
          ],
          "type": "string"
        }
      },
      "required": [
        "PolicyName",
        "PolicyType"
      ],
      "type": "object"
    },
    "Tag": {
      "description": "Tag",
      "properties": {
        "Key": {
          "description": "Tag key",
          "type": "string"
        },
        "Value": {
          "description": "Tag value",
          "type": "string"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "type": "object"
    }
  },
  "description": "A role is a virtual identity in the IAM system that grants certain access permissions within an account to various identity entities. Trusted identity entities can assume this role to access cloud resources within the account.",
  "handlers": {
    "create": {
      "permissions": [
        "iam:CreateRole",
        "iam:AttachRolePolicy",
        "iam:GetRole",
        "iam:ListAttachedRolePolicies"
      ]
    },
    "delete": {
      "permissions": [
        "iam:DeleteRole",
        "iam:GetRole"
      ]
    },
    "list": {
      "permissions": [
        "iam:ListRoles"
      ]
    },
    "read": {
      "permissions": [
        "iam:GetRole",
        "iam:ListAttachedRolePolicies"
      ]
    },
    "update": {
      "permissions": [
        "iam:UpdateRole",
        "iam:AttachRolePolicy",
        "iam:DetachRolePolicy",
        "iam:GetRole",
        "iam:ListAttachedRolePolicies",
        "iam:TagResources",
        "iam:UntagResources"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/RoleName"
  ],
  "properties": {
    "CreateDate": {
      "description": "Role creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Role description, maximum length 128",
      "semantic": "description",
      "type": "string"
    },
    "DisplayName": {
      "description": "Role display name, maximum length 64",
      "type": "string"
    },
    "IsServiceLinkedRole": {
      "description": "Service-linked role or not: 0 for No, 1 for Yes",
      "enum": [
        0,
        1
      ],
      "type": "integer"
    },
    "MaxSessionDuration": {
      "description": "Maximum session duration for the role. Maximum session duration for the role. Limits the maximum validity period of temporary security credentials generated by role assumption. Value range: 3600–43200, unit: seconds, default is 43200",
      "maximum": 43200,
      "minimum": 3600,
      "type": "integer"
    },
    "Policies": {
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Policy"
      },
      "type": "array",
      "uniqueItems": true
    },
    "RoleId": {
      "description": "Role ID",
      "semantic": "resourceId",
      "type": "integer"
    },
    "RoleName": {
      "description": "Role name, length 1–64, supports English letters, numbers, and .-_ characters",
      "semantic": "resourceName",
      "type": "string"
    },
    "Tags": {
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "Trn": {
      "description": "Role TRN",
      "type": "string"
    },
    "TrustPolicyDocument": {
      "description": "Role trust policy. The trust policy follows resource-based policy rules in IAM policy syntax.",
      "type": "string"
    },
    "UpdateDate": {
      "description": "Role update time",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/IsServiceLinkedRole",
    "/properties/Trn",
    "/properties/RoleId",
    "/properties/CreateDate",
    "/properties/UpdateDate"
  ],
  "required": [
    "RoleName"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::IAM::Role"
}