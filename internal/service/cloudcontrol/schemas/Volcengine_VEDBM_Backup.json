{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/BackupType",
    "/properties/BackupMethod"
  ],
  "description": "Cloud Database veDB Backup Management",
  "filterProperties": {
    "filterableProperties": [
      "/properties/InstanceId",
      "/properties/BackupType",
      "/properties/BackupStartTime",
      "/properties/BackupEndTime",
      "/properties/BackupStatus",
      "/properties/BackupMethod"
    ],
    "required": [
      "/properties/InstanceId"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "vedbm:CreateBackup",
        "vedbm:DescribeBackups",
        "vedbm:DescribeBackupPolicy"
      ]
    },
    "delete": {
      "permissions": [
        "vedbm:DeleteBackup",
        "vedbm:DescribeBackups",
        "vedbm:DescribeBackupPolicy"
      ]
    },
    "list": {
      "permissions": [
        "vedbm:DescribeBackups",
        "vedbm:DescribeBackupPolicy"
      ]
    },
    "read": {
      "permissions": [
        "vedbm:DescribeBackups",
        "vedbm:DescribeBackupPolicy"
      ]
    },
    "update": {
      "permissions": [
        "vedbm:ModifyBackupPolicy",
        "vedbm:DescribeBackups",
        "vedbm:DescribeBackupPolicy"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/InstanceId",
    "/properties/BackupId"
  ],
  "properties": {
    "BackupEndTime": {
      "description": "Backup end time, format: yyyy-MM-ddTHH:mm:ssZ (UTC time)",
      "type": "string"
    },
    "BackupFileSize": {
      "description": "Backup file size, unit: KiB",
      "format": "int32",
      "type": "integer"
    },
    "BackupId": {
      "description": "Backup ID",
      "type": "string"
    },
    "BackupMethod": {
      "description": "Backup method, currently only physical backup is supported",
      "type": "string"
    },
    "BackupRetentionPeriod": {
      "description": "Data backup retention days",
      "type": "integer"
    },
    "BackupStartTime": {
      "description": "Backup start time, format: yyyy-MM-ddTHH:mm:ssZ (UTC time)",
      "type": "string"
    },
    "BackupStatus": {
      "description": "Backup status",
      "type": "string"
    },
    "BackupTime": {
      "description": "Backup task execution time, interval window is two hours. Format: HH:mmZ-HH:mmZ (UTC time)",
      "type": "string"
    },
    "BackupType": {
      "description": "Backup type, currently only full backup is supported",
      "type": "string"
    },
    "ConsistentTime": {
      "description": "Consistency backup timestamp, format: yyyy-MM-ddTHH:mm:ssZ (UTC time)",
      "type": "string"
    },
    "ContinueBackup": {
      "description": "Enable continuous backup, value is always true",
      "type": "boolean"
    },
    "CreateType": {
      "description": "Creation type",
      "type": "string"
    },
    "FullBackupPeriod": {
      "description": "Full backup cycle, use commas (,) to separate multiple values",
      "type": "string"
    },
    "InstanceId": {
      "description": "Instance ID",
      "semantic": "resourceId",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/BackupId",
    "/properties/ContinueBackup",
    "/properties/BackupStatus",
    "/properties/CreateType",
    "/properties/BackupFileSize",
    "/properties/BackupStartTime",
    "/properties/BackupEndTime",
    "/properties/ConsistentTime"
  ],
  "required": [
    "InstanceId"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::VEDBM::Backup"
}