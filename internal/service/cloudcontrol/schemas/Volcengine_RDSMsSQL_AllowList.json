{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ProjectName",
    "/properties/AllowListType"
  ],
  "definitions": {
    "Instance": {
      "properties": {
        "InstanceId": {
          "description": "Instance ID",
          "type": "string"
        },
        "InstanceName": {
          "description": "Instance name",
          "type": "string"
        },
        "InstanceStatus": {
          "description": "Instance status",
          "type": "string"
        },
        "IsLatest": {
          "description": "Sync latest allowlist IP",
          "type": "boolean"
        },
        "ProjectName": {
          "description": "Project name of the instance",
          "type": "string"
        },
        "VPC": {
          "description": "VPC ID of the instance",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "API request parameter - Create RDS SQL Server allowlist (CreateAllowList)",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "rds_mssql:CreateAllowList",
        "rds_mssql:DescribeAllowLists",
        "rds_mssql:AssociateAllowList"
      ]
    },
    "delete": {
      "permissions": [
        "rds_mssql:DeleteAllowList",
        "rds_mssql:DescribeAllowListDetail",
        "rds_mssql:DisassociateAllowList"
      ]
    },
    "list": {
      "permissions": [
        "rds_mssql:DescribeAllowLists",
        "rds_mssql:DescribeInstanceAllowLists"
      ]
    },
    "read": {
      "permissions": [
        "rds_mssql:DescribeAllowLists",
        "rds_mssql:DescribeAllowListDetail"
      ]
    },
    "update": {
      "permissions": [
        "rds_mssql:ModifyAllowList",
        "rds_mssql:AssociateAllowList",
        "rds_mssql:DisassociateAllowList"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/AllowListId"
  ],
  "properties": {
    "AllowList": {
      "description": "IP allowlist. Separate multiple IP addresses with commas (,). No duplicates allowed",
      "type": "string"
    },
    "AllowListCategory": {
      "description": "Allowlist category",
      "type": "string"
    },
    "AllowListDesc": {
      "description": "Allowlist description",
      "semantic": "description",
      "type": "string"
    },
    "AllowListIPNum": {
      "description": "Allowlist IP count",
      "format": "int64",
      "type": "integer"
    },
    "AllowListId": {
      "description": "Allowlist ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "AllowListName": {
      "description": "Allowlist name",
      "semantic": "resourceName",
      "type": "string"
    },
    "AllowListType": {
      "description": "IP address type in the allowlist. Only IPv4 is supported",
      "type": "string"
    },
    "AssociatedInstanceNum": {
      "description": "Number of bound instances. Required when unbinding an instance from the allowlist",
      "format": "int64",
      "type": "integer"
    },
    "AssociatedInstances": {
      "description": "Bound instance list",
      "insertionOrder": true,
      "items": {
        "$ref": "#/definitions/Instance"
      },
      "type": "array",
      "uniqueItems": true
    },
    "InstanceId": {
      "description": "Instance ID",
      "type": "string"
    },
    "ProjectName": {
      "description": "Project name",
      "type": "string"
    },
    "UserAllowList": {
      "description": "IP addresses outside the security group that need to be added to the allowlist. Enter IP addresses or CIDR-formatted IP ranges. If both this field and AllowList are specified, AllowList takes precedence",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AllowListId",
    "/properties/AllowListIPNum",
    "/properties/AssociatedInstances/*/InstanceName",
    "/properties/AssociatedInstances/*/VPC",
    "/properties/AssociatedInstances/*/IsLatest",
    "/properties/AssociatedInstances/*/ProjectName",
    "/properties/AssociatedInstances/*/InstanceStatus"
  ],
  "required": [
    "AllowListName"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::RDSMsSQL::AllowList"
}