      "description": "Backup Policy",
      "type": "object"
    },
    "PolicyId": {
      "description": "Backup Policy ID",
      "type": "string"
    },
    "ResourceList": {
      "description": "Backup Source List",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/ResourceList"
      },
      "type": "array",
      "uniqueItems": true
    },
    "UpdatedTime": {
      "description": "Update Time",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
