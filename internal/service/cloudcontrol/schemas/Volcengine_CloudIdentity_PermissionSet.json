  "definitions": {
    "PermissionPolicy": {
      "description": "Permission Policy Definition",
      "properties": {
        "CreatedTime": {
          "description": "Policy Creation Time",
          "type": "string"
        },
        "PermissionPolicyDocument": {
          "description": "Policy syntax content. Refer to policy syntax documentation",
