      ]
    },
    "read": {
      "permissions": [
        "cloudidentity:GetPermissionSet",
        "cloudidentity:ListPermissionPoliciesInPermissionSet",
        "cloudidentity:ListPermissionSets"
      ]
    },
    "update": {
      "permissions": [
        "cloudidentity:UpdatePermissionSet",
        "cloudidentity:AddSystemPolicyToPermissionSet",
        "cloudidentity:AddInlinePolicyToPermissionSet",
        "cloudidentity:UpdateInlinePolicyToPermissionSet",
        "cloudidentity:RemovePermissionPolicyFromPermissionSet",
        "cloudidentity:GetPermissionSet",
        "cloudidentity:ListPermissionPoliciesInPermissionSet",
        "cloudidentity:ListPermissionSets"
      ]
    }
  },
