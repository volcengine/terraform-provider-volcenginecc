{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/TemplateType",
    "/properties/TemplateTypeVersion"
  ],
  "definitions": {
    "TemplateParam": {
      "description": "Parameter definitions in the parameter template",
      "properties": {
        "CheckingCode": {
          "description": "Parameter validation rules",
          "type": "string"
        },
        "DefaultValue": {
          "description": "Default value of the parameter",
          "type": "string"
        },
        "Description": {
          "description": "Parameter description information in English",
          "type": "string"
        },
        "DescriptionZH": {
          "description": "Parameter description information in Chinese",
          "type": "string"
        },
        "ForceRestart": {
          "description": "Whether modifying this parameter requires a restart",
          "type": "boolean"
        },
        "Name": {
          "description": "Parameter name",
          "type": "string"
        },
        "Type": {
          "description": "Data type of the parameter",
          "type": "string"
        },
        "Value": {
          "description": "Parameter value",
          "type": "string"
        }
      },
      "required": [
        "Name",
        "Value"
      ],
      "type": "object"
    }
  },
  "description": "Volcano Engine Cloud Database PostgreSQL parameter template, used for managing and batch applying PostgreSQL instance parameter configurations",
  "filterProperties": {
    "filterableProperties": [
      "/properties/TemplateCategory",
      "/properties/TemplateSource",
      "/properties/TemplateType",
      "/properties/TemplateTypeVersion"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "rds_postgresql:CreateParameterTemplate",
        "rds_postgresql:DescribeParameterTemplate"
      ]
    },
    "delete": {
      "permissions": [
        "rds_postgresql:DeleteParameterTemplate",
        "rds_postgresql:DescribeParameterTemplate"
      ]
    },
    "list": {
      "permissions": [
        "rds_postgresql:ListParameterTemplates"
      ]
    },
    "read": {
      "permissions": [
        "rds_postgresql:DescribeParameterTemplate"
      ]
    },
    "update": {
      "permissions": [
        "rds_postgresql:ModifyParameterTemplate",
        "rds_postgresql:DescribeParameterTemplate"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/TemplateId"
  ],
  "properties": {
    "AccountId": {
      "description": "Account ID",
      "type": "string"
    },
    "CreateTime": {
      "description": "Parameter template creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "NeedRestart": {
      "description": "Whether the template contains parameters that require a restart to take effect",
      "type": "boolean"
    },
    "ParameterNum": {
      "description": "Number of parameters included in the template",
      "type": "integer"
    },
    "TemplateCategory": {
      "description": "Template category",
      "type": "string"
    },
    "TemplateDesc": {
      "description": "Parameter template description information",
      "semantic": "description",
      "type": "string"
    },
    "TemplateId": {
      "description": "Parameter template ID, automatically generated by the system",
      "semantic": "resourceId",
      "type": "string"
    },
    "TemplateName": {
      "description": "Parameter template name",
      "semantic": "resourceName",
      "type": "string"
    },
    "TemplateParams": {
      "description": "List of parameters included in the parameter template",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/TemplateParam"
      },
      "type": "array",
      "uniqueItems": true
    },
    "TemplateSource": {
      "description": "Parameter template source type. Options: System (system template), User (user template)",
      "type": "string"
    },
    "TemplateType": {
      "description": "Database type of the parameter template. Value: PostgreSQL",
      "type": "string"
    },
    "TemplateTypeVersion": {
      "description": "Database version of the parameter template, such as PostgreSQL_13, PostgreSQL_14, PostgreSQL_15, etc",
      "type": "string"
    },
    "UpdateTime": {
      "description": "Last modified time of the parameter template",
      "semantic": "updatedTime",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/TemplateId",
    "/properties/AccountId",
    "/properties/CreateTime",
    "/properties/UpdateTime",
    "/properties/NeedRestart",
    "/properties/ParameterNum",
    "/properties/TemplateParams/*/DefaultValue",
    "/properties/TemplateParams/*/Description",
    "/properties/TemplateParams/*/DescriptionZH",
    "/properties/TemplateParams/*/CheckingCode",
    "/properties/TemplateParams/*/ForceRestart",
    "/properties/TemplateParams/*/Type",
    "/properties/TemplateCategory",
    "/properties/TemplateSource"
  ],
  "required": [
    "TemplateName",
    "TemplateType",
    "TemplateParams",
    "TemplateTypeVersion"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::RDSPostgreSQL::ParameterTemplate"
}