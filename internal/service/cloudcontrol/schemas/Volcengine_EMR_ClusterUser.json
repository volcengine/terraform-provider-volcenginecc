{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ClusterId",
    "/properties/UserName"
  ],
  "description": "Users in an E-MapReduce (EMR) cluster are divided into regular users and system users. Regular users are added to the cluster manually through import or creation in the user management module. System users are built-in management users for each component created during cluster initialization and cannot be edited or deleted.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ClusterId",
      "/properties/UserName",
      "/properties/CreatorName",
      "/properties/UserGroupNames"
    ],
    "required": [
      "/properties/ClusterId"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "emr:CreateClusterUser",
        "emr:ListClusterUsers"
      ]
    },
    "delete": {
      "permissions": [
        "emr:DeleteClusterUser",
        "emr:ListClusterUsers"
      ]
    },
    "list": {
      "permissions": [
        "emr:ListClusterUsers"
      ]
    },
    "read": {
      "permissions": [
        "emr:ListClusterUsers"
      ]
    },
    "update": {
      "permissions": [
        "emr:UpdateClusterUserPassword",
        "emr:UpdateClusterUser",
        "emr:ListClusterUsers"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/ClusterId",
    "/properties/UserName"
  ],
  "properties": {
    "ClusterId": {
      "description": "Cluster ID.",
      "type": "string"
    },
    "CreatedTime": {
      "description": "Creation time.",
      "format": "int64",
      "semantic": "createdTime",
      "type": "integer"
    },
    "CreatorName": {
      "description": "Creator username.",
      "type": "string"
    },
    "Description": {
      "description": "User group description.",
      "semantic": "description",
      "type": "string"
    },
    "OldPassword": {
      "description": "Old user login password. Required when changing password.",
      "maxLength": 20,
      "type": "string"
    },
    "Password": {
      "description": "New user login password. Password must be 8–20 characters long, support numbers, letters, -, _, and contain at least one number and one letter.",
      "maxLength": 20,
      "type": "string"
    },
    "UpdatedTime": {
      "description": "Last updated time.",
      "format": "int64",
      "semantic": "updatedTime",
      "type": "integer"
    },
    "UserGroupNames": {
      "description": "User group name.",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "UserName": {
      "description": "Cluster username. Only lowercase letters are supported.",
      "semantic": "resourceId",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/CreatedTime",
    "/properties/UpdatedTime",
    "/properties/CreatorName"
  ],
  "required": [
    "ClusterId",
    "UserName",
    "Password"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::EMR::ClusterUser",
  "writeOnlyProperties": [
    "/properties/Password",
    "/properties/OldPassword"
  ]
}