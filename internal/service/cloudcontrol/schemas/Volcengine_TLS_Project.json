      "/properties/ProjectID",
      "/properties/ProjectName",
      "/properties/IamProjectName",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "TLS:CreateProject",
        "TLS:DescribeProject"
      ]
    },
    "delete": {
      "permissions": [
        "TLS:DeleteProject",
        "TLS:DescribeProject"
      ]
    },
    "list": {
      "permissions": [
        "TLS:DescribeProjects"
      ]
    },
    "read": {
      "permissions": [
        "TLS:DescribeProject"
      ]
    },
    "update": {
      "permissions": [
        "TLS:ModifyProject",
        "TLS:DescribeProject",
        "TLS:AddTagsToResource",
        "TLS:RemoveTagsFromResource"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/ProjectID"
  ],
  "properties": {
    "CreatedTime": {
      "description": "Log project creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Brief description of the log project",
      "semantic": "description",
      "type": "string"
    },
    "IamProjectName": {
      "description": "The IAM project associated with the log project",
