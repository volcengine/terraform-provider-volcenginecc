      "semantic": "resourceId",
      "type": "string"
    },
    "ProjectName": {
      "description": "Log project name",
      "semantic": "resourceName",
      "type": "string"
    },
    "Tags": {
      "description": "Tag information",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "TopicCount": {
      "description": "Number of log topics in the current log project",
      "type": "integer"
