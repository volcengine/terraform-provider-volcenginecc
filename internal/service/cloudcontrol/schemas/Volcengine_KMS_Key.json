{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/KeySpec",
    "/properties/KeyUsage",
    "/properties/MultiRegion",
    "/properties/Origin",
    "/properties/ProtectionLevel",
    "/properties/RotateInterval",
    "/properties/KeyringName"
  ],
  "definitions": {
    "AsymmetricCiphertext": {
      "description": "Asymmetric encryption action parameters and results.",
      "properties": {
        "Algorithm": {
          "description": "Encryption algorithm. Optional values: RSAES_OAEP_SHA_256, SM2PKE.",
          "type": "string"
        },
        "CiphertextBlob": {
          "description": "Ciphertext of encryption result, Base64-encoded.",
          "type": "string"
        },
        "Plaintext": {
          "description": "Plaintext to be encrypted, Base64-encoded.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "AsymmetricSignature": {
      "description": "Asymmetric signature action parameters and results.",
      "properties": {
        "Algorithm": {
          "description": "Signature algorithm, for example: RSA_PSS_SHA_256, RSA_PKCS1_SHA_256, ECDSA_SHA_256, SM2_DSA.",
          "type": "string"
        },
        "Message": {
          "description": "Message to be signed, Base64-encoded.",
          "type": "string"
        },
        "MessageType": {
          "description": "Message type. Optional values: RAW, DIGEST.",
          "type": "string"
        },
        "Signature": {
          "description": "Signature result, Base64-encoded.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "Ciphertext": {
      "description": "Symmetric encryption action parameters and results.",
      "properties": {
        "CiphertextBlob": {
          "description": "Ciphertext of encryption result, Base64-encoded.",
          "type": "string"
        },
        "EncryptionContext": {
          "description": "Encryption context JSON string.",
          "type": "string"
        },
        "Plaintext": {
          "description": "Plaintext to be encrypted, Base64-encoded.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "MultiRegionConfiguration": {
      "properties": {
        "MultiRegionKeyType": {
          "description": "Multi-region key type.",
          "type": "string"
        },
        "PrimaryKey": {
          "$ref": "#/definitions/PrimaryKey",
          "description": "Primary multi-region key transaction identifier and region ID.",
          "type": "object"
        },
        "ReplicaKeys": {
          "description": "Replica multi-region key transaction record number and region ID.",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/ReplicaKey"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "type": "object"
    },
    "PrimaryKey": {
      "description": "Primary multi-region key transaction identifier and region ID.",
      "properties": {
        "Region": {
          "description": "Multi-region key region ID.",
          "type": "string"
        },
        "Trn": {
          "description": "Multi-region key TRN.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "ReEncrypt": {
      "description": "Re-encryption action parameters and results.",
      "properties": {
        "CiphertextBlob": {
          "description": "Re-encrypted ciphertext, Base64-encoded.",
          "type": "string"
        },
        "NewEncryptionContext": {
          "description": "New encryption context JSON string.",
          "type": "string"
        },
        "NewKeyID": {
          "description": "Target key ID. If not specified, you must provide NewKeyringName and NewKeyName.",
          "type": "string"
        },
        "NewKeyName": {
          "description": "Target key name.",
          "type": "string"
        },
        "NewKeyringName": {
          "description": "Name of the keyring to which the target key belongs.",
          "type": "string"
        },
        "OldEncryptionContext": {
          "description": "Old encryption context JSON string.",
          "type": "string"
        },
        "SourceCiphertextBlob": {
          "description": "Source ciphertext to be re-encrypted, Base64-encoded.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "ReplicaKey": {
      "description": "Replica multi-region key transaction record number and region ID.",
      "properties": {
        "Region": {
          "description": "Multi-region key region ID.",
          "type": "string"
        },
        "Trn": {
          "description": "Multi-region key conversion.",
          "type": "string"
        }
      },
      "type": "object"
    },
    "ReplicateKeyOperation": {
      "description": "Replicate key action parameters and results.",
      "properties": {
        "Description": {
          "description": "Replica key description.",
          "type": "string"
        },
        "ReplicaKeyID": {
          "description": "Replica key ID.",
          "type": "string"
        },
        "ReplicaRegion": {
          "description": "Target region of the replica key.",
          "type": "string"
        },
        "Tags": {
          "description": "Replica key label.",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/Tag"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "type": "object"
    },
    "Tag": {
      "description": "KMS key label.",
      "properties": {
        "Key": {
          "description": "KMS key label key.",
          "type": "string"
        },
        "Value": {
          "description": "KMS key label value.",
          "type": "string"
        }
      },
      "required": [
        "Key",
        "Value"
      ],
      "type": "object"
    }
  },
  "description": "Key Management Service (KMS) is a one-stop key management and data encryption platform on Volcano Engine. It provides easy-to-use encryption interfaces. KMS helps users easily manage keys and protect the security of core cloud data. It also greatly reduces the procurement and development costs for users to deploy their own cryptographic infrastructure. KMS helps businesses easily meet regulatory and compliance requirements.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/KeyringName",
      "/properties/KeyName",
      "/properties/KeySpec",
      "/properties/Description",
      "/properties/KeyState",
      "/properties/KeyUsage",
      "/properties/ProtectionLevel",
      "/properties/RotateState",
      "/properties/Origin",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ],
    "required": [
      "/properties/KeyringName"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "kms:CreateKey",
        "kms:DescribeKey",
        "kms:ArchiveKey",
        "kms:CancelArchiveKey",
        "kms:EnableKey",
        "kms:DisableKey",
        "kms:EnableKeyRotation",
        "kms:DisableKeyRotation",
        "kms:Encrypt",
        "kms:AsymmetricEncrypt",
        "kms:AsymmetricSign",
        "kms:ReEncrypt",
        "kms:ReplicateKey",
        "kms:UpdatePrimaryRegion"
      ]
    },
    "delete": {
      "permissions": [
        "kms:ScheduleKeyDeletion",
        "kms:DescribeKey"
      ]
    },
    "list": {
      "permissions": [
        "kms:DescribeKeys"
      ]
    },
    "read": {
      "permissions": [
        "kms:DescribeKey"
      ]
    },
    "update": {
      "permissions": [
        "kms:UpdateKey",
        "kms:UntagResources",
        "kms:TagResources",
        "kms:DescribeKey",
        "kms:ArchiveKey",
        "kms:CancelArchiveKey",
        "kms:EnableKey",
        "kms:DisableKey",
        "kms:EnableKeyRotation",
        "kms:DisableKeyRotation",
        "kms:Encrypt",
        "kms:AsymmetricEncrypt",
        "kms:AsymmetricSign",
        "kms:ReEncrypt",
        "kms:ReplicateKey",
        "kms:UpdatePrimaryRegion"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/KeyringName",
    "/properties/KeyID"
  ],
  "properties": {
    "AsymmetricCiphertext": {
      "$ref": "#/definitions/AsymmetricCiphertext",
      "description": "Asymmetric encryption action parameters and results. AsymmetricEncrypt can be triggered during the Create/Update phase; the result is only guaranteed to be returned in the current response.",
      "type": "object"
    },
    "AsymmetricSignature": {
      "$ref": "#/definitions/AsymmetricSignature",
      "description": "Asymmetric signature action parameters and results. AsymmetricSign can be triggered during the Create/Update phase; the result is only guaranteed to be returned in the current response.",
      "type": "object"
    },
    "Ciphertext": {
      "$ref": "#/definitions/Ciphertext",
      "description": "Symmetric encryption action parameters and results. Encrypt can be triggered during the Create/Update phase; the result is only guaranteed to be returned in the current response.",
      "type": "object"
    },
    "CreatedTime": {
      "description": "Key creation time.",
      "format": "int64",
      "semantic": "createdTime",
      "type": "integer"
    },
    "Description": {
      "description": "Key description: Length 0–8192 characters.",
      "maxLength": 8192,
      "minLength": 0,
      "semantic": "description",
      "type": "string"
    },
    "KeyArchiveOperation": {
      "description": "User master key archive operation (enter 1 to archive, 2 to unarchive).",
      "format": "int32",
      "type": "integer"
    },
    "KeyEnableOperation": {
      "description": "User master key enable operation (enter 1 to enable, 2 to disable).",
      "format": "int32",
      "type": "integer"
    },
    "KeyID": {
      "description": "Key unique identifier in UUID format.",
      "semantic": "resourceId",
      "type": "string"
    },
    "KeyMaterialExpireTime": {
      "description": "Key material expiration time. If empty, the key does not expire.",
      "type": "string"
    },
    "KeyName": {
      "description": "Master key name. Length 2–31 characters. Valid characters: [a-zA-Z0-9-_].",
      "maxLength": 31,
      "minLength": 2,
      "semantic": "resourceName",
      "type": "string"
    },
    "KeyPrimaryRegion": {
      "description": "Primary region of the multi-region key. Set the target primary region during the Create/Update phase; the current primary region is returned during the Read phase.",
      "type": "string"
    },
    "KeyRotationOperation": {
      "description": "User master key rotation operation (enter 1 to enable, 2 to disable).",
      "format": "int32",
      "type": "integer"
    },
    "KeySpec": {
      "description": "Symmetric keys: SYMMETRIC_256, SYMMETRIC_128; asymmetric keys: RSA_2048, RSA_3072, RSA_4096, EC_P256, EC_P256K, EC_P384, EC_P521, EC_SM2.",
      "type": "string"
    },
    "KeyState": {
      "description": "Key status: Enable, Disable, PendingDelete, Archived, PendingImport.",
      "semantic": "status",
      "type": "string"
    },
    "KeyUsage": {
      "description": "Key usage. Options: ENCRYPT_DECRYPT, SIGN_VERIFY, GENERATE_VERIFY_MAC.",
      "type": "string"
    },
    "KeyringName": {
      "description": "Key ring name. Length 2–31 characters. Valid characters: [a-zA-Z0-9-_].",
      "maxLength": 31,
      "minLength": 2,
      "type": "string"
    },
    "LastRotationTime": {
      "description": "Key last rotation time.",
      "type": "string"
    },
    "MultiRegion": {
      "description": "Is this a multi-region type master key.",
      "type": "boolean"
    },
    "MultiRegionConfiguration": {
      "$ref": "#/definitions/MultiRegionConfiguration",
      "description": "Multi-region key configuration information.",
      "type": "object"
    },
    "Origin": {
      "description": "Key source. Options: CloudKMS, External, ExternalKeyStore.",
      "type": "string"
    },
    "ProtectionLevel": {
      "description": "Key protection level. Options: SOFTWARE, HSM.",
      "type": "string"
    },
    "ReEncrypt": {
      "$ref": "#/definitions/ReEncrypt",
      "description": "Re-encryption action parameters and results. ReEncrypt can be triggered during the Create/Update phase; the result is only guaranteed to be returned in the current response.",
      "type": "object"
    },
    "ReplicateKey": {
      "$ref": "#/definitions/ReplicateKeyOperation",
      "description": "Replicate key action parameters and results. ReplicateKey can be triggered during the Create/Update phase; the result is only guaranteed to be returned in the current response.",
      "type": "object"
    },
    "RotateInterval": {
      "description": "Key rotation period (days). Range: [90, 2560].",
      "type": "integer"
    },
    "RotateState": {
      "description": "Key rotation status. Options: Enable, Disable.",
      "type": "string"
    },
    "ScheduleDeleteTime": {
      "description": "Key deletion time.",
      "type": "string"
    },
    "ScheduleRotationTime": {
      "description": "Key rotation time.",
      "type": "string"
    },
    "Tags": {
      "description": "KMS key label information.",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "Trn": {
      "description": "Resource name. Format should be trn:${Service}:${Region}:${AccountID}:${ResourcePath}.",
      "type": "string"
    },
    "UpdatedTime": {
      "description": "Key update time.",
      "format": "int64",
      "semantic": "updatedTime",
      "type": "integer"
    }
  },
  "readOnlyProperties": [
    "/properties/KeyState",
    "/properties/CreatedTime",
    "/properties/KeyID",
