{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ChargeType",
    "/properties/ClusterType",
    "/properties/DeployMode",
    "/properties/HistoryServerMode",
    "/properties/NodeAttribute",
    "/properties/ProjectName",
    "/properties/ReleaseVersion",
    "/properties/SecurityGroupId",
