  "definitions": {
    "Application": {
      "properties": {
        "ApplicationConfigHome": {
          "description": "应用配置路径。",
          "type": "string"
        },
        "ApplicationHome": {
          "description": "应用安装路径。",
          "type": "string"
        },
        "ApplicationName": {
          "description": "应用名称。",
          "type": "string"
        },
        "ApplicationState": {
          "description": "服务状态。NORMAL：正常；WARNING：告警；STOPPED：已停止；INIT：初始化中；INSTALLING：安装中；INSTALLED：已安装；STARTING：启动中；STARTED：已启动；STOPPING：停止中；UNINSTALLING：卸载中；UNINSTALLED：已卸载；EXCEPTION：异常。",
          "type": "string"
        },
        "ApplicationVersion": {
          "description": "应用版本。",
          "type": "string"
        },
        "Group": {
          "description": "应用用户组。",
          "type": "string"
        },
        "SupportClient": {
          "description": "是否支持客户端。",
          "type": "boolean"
        },
        "User": {
          "description": "应用用户。",
          "type": "string"
        }
      },
      "type": "object"
    },
    "ApplicationComponentLayout": {
      "properties": {
        "ComponentName": {
          "description": "组件名称。",
          "type": "string"
        },
        "EffectiveScope": {
          "$ref": "#/definitions/EffectiveScope",
