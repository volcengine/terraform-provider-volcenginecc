      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "ClusterId": {
      "description": "集群ID。",
      "semantic": "resourceId",
      "type": "string"
    },
    "ClusterName": {
      "description": "集群名称。",
      "semantic": "resourceName",
      "type": "string"
    },
    "ClusterState": {
      "description": "集群状态。",
      "semantic": "status",
      "type": "string"
    },
    "ClusterType": {
      "description": "集群类型。",
      "type": "string"
    },
    "CreatedTime": {
      "description": "集群创建时间。",
      "format": "int64",
      "semantic": "createdTime",
      "type": "integer"
    },
    "CreatorId": {
      "description": "创建者ID。",
