  "description": "E-MapReduce（EMR）是开源 Hadoop 生态的企业级大数据分析系统，完全兼容开源，为您提供 Hadoop、Spark、Hive、Hudi、Iceberg 等生态组件集成和管理。",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ClusterId",
      "/properties/ClusterName",
      "/properties/ProjectName",
      "/properties/ReleaseVersion",
      "/properties/ChargeType",
      "/properties/ClusterState",
      "/properties/ClusterType",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "emr:CreateCluster",
        "emr:GetCluster",
        "emr:ListApplications"
      ]
    },
    "delete": {
      "permissions": [
        "emr:ReleaseCluster",
        "emr:GetCluster"
      ]
    },
    "list": {
      "permissions": [
        "emr:ListClusters"
      ]
    },
    "read": {
      "permissions": [
        "emr:GetCluster",
        "emr:ListApplications"
      ]
    },
    "update": {
      "permissions": [
        "emr:UpdateClusterAttribute",
        "emr:GetCluster",
        "emr:ListApplications",
        "emr:UntagResources",
        "emr:TagResources"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/ClusterId"
  ],
  "properties": {
    "AccountId": {
      "description": "账号ID。",
      "format": "int64",
      "type": "integer"
    },
    "ApplicationExtras": {
      "description": "集群服务的扩展信息列表，包括服务的自定义配置项、服务组件的自定义部署拓扑设置，以及服务的元数据连接配置信息。",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/ApplicationExtra"
      },
      "type": "array",
      "uniqueItems": false
    },
    "ApplicationNames": {
      "description": "集群安装的服务名称列表。创建字段。",
      "insertionOrder": false,
      "items": {
        "type": "string"
      },
      "type": "array",
      "uniqueItems": true
    },
    "Applications": {
      "description": "集群安装的服务列表。只读字段。",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Application"
      },
      "type": "array",
      "uniqueItems": true
    },
    "BootstrapScripts": {
      "description": "集群的引导脚本列表。",
