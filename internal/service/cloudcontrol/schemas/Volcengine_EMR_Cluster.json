    },
    "ApplicationConfig": {
      "properties": {
        "ComponentInstanceName": {
          "description": "组件实例名称。",
          "type": "string"
        },
        "ComponentName": {
          "description": "组件名称。",
          "type": "string"
        },
        "ConfigFileName": {
          "description": "配置文件名。",
          "type": "string"
        },
        "ConfigItemKey": {
          "description": "配置项名称。",
          "type": "string"
        },
        "ConfigItemValue": {
          "description": "配置项值。",
          "type": "string"
        },
        "Deleted": {
          "description": "是否删除。",
          "type": "boolean"
        },
        "EffectiveScope": {
          "$ref": "#/definitions/EffectiveScope",
          "description": "影响组件。",
          "type": "object"
        }
      },
      "type": "object"
    },
    "ApplicationExtra": {
      "properties": {
        "ApplicationComponentLayouts": {
          "description": "服务组件的自定义部署拓扑列表。",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/ApplicationComponentLayout"
          },
          "type": "array",
          "uniqueItems": true
        },
        "ApplicationConfigs": {
          "description": "服务的自定义配置参数列表。",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/ApplicationConfig"
          },
          "type": "array",
          "uniqueItems": false
        },
        "ApplicationName": {
          "description": "应用名称。",
          "type": "string"
        },
        "ConnectionId": {
          "description": "元数据连接id。",
          "type": "string"
        },
        "ConnectionType": {
          "description": "元数据连接类型。BUILT_IN_MYSQL：内置数据库。EXTERNAL_MYSQL：外置数据库。HIVE_METASTORE：HMS。",
          "type": "string"
        }
      },
      "type": "object"
    },
    "BootstrapScript": {
      "properties": {
        "EffectiveScope": {
          "$ref": "#/definitions/EffectiveScope",
          "description": "脚本执行范围。",
          "type": "object"
        },
        "ExecutionFailStrategy": {
          "description": "执行失败策略。取值范围：FAILED_CONTINUE：失败后继续执行其他任务。FAILED_BLOCK：失败后中断，不再继续执行后续任务。当脚本为BOOTSTRAP时，会导致创建集群、扩容节点组操作中断并失败。默认值：FAILED_BLOCK。",
          "enum": [
            "FAILED_CONTINUE",
            "FAILED_BLOCK"
          ],
          "type": "string"
        },
        "ExecutionMoment": {
          "description": "脚本的执行时机。仅scriptType=BOOTSTRAP时生效。BEFORE_APPLICATION_INSTALL：应用安装前。AFTER_APPLICATION_STARTED：应用启动后。默认值：BEFORE_APP_INSTALL",
          "enum": [
            "BEFORE_APPLICATION_INSTALL",
            "AFTER_APPLICATION_STARTED"
          ],
          "type": "string"
        },
        "Priority": {
          "description": "脚本执行优先级。取值范围：1~1000。默认值1。",
          "maxLength": 1000,
          "type": "string"
        },
        "ScriptArgs": {
          "description": "脚本参数。",
          "type": "string"
        },
        "ScriptName": {
          "description": "脚本名称。必填。长度为1~128个字符，必须以大小字母或中文开头，不能以 http:： 和 https:： 开头。可以包含中文、英文、数字、下划线（_）、或者短划线（-）。",
          "maxLength": 128,
          "type": "string"
        },
        "ScriptPath": {
          "description": "脚本所在TOS路径。必填。以 tos:： 开头。",
          "type": "string"
        },
        "ScriptType": {
          "description": "脚本类型。NORMAL：普通脚本。BOOTSTRAP：引导脚本。",
          "enum": [
            "NORMAL",
            "BOOTSTRAP"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "ChargePreConfig": {
      "properties": {
        "AutoRenew": {
          "description": "是否开启自动续费。取值范围：true：开启。false：不开启。",
          "type": "boolean"
        },
        "AutoRenewPeriod": {
          "description": "自动续费触发时的续费时长，当AutoRenew=true时，默认值=1。",
          "type": "integer"
        },
        "AutoRenewPeriodUnit": {
          "description": "自动续费触发时的续费时长单位，当AutoRenew=true时，默认值=Month。取值范围：Month：月。Year：年。",
          "enum": [
            "Month",
            "Year"
          ],
          "type": "string"
        },
        "ChargePeriod": {
          "description": "chargeType=PRE默认值=1，包月的购买时长单位。",
          "type": "integer"
        },
        "ChargePeriodUnit": {
          "description": "chargeType=PRE时，默认值=Month，包月的购买时长单位，取值范围：Month：月。Year：年。",
          "enum": [
            "Month",
            "Year"
          ],
          "type": "string"
        },
        "ChargeType": {
          "description": "付费类型，取值范围：PRE，POST。",
          "enum": [
            "PRE",
            "POST"
          ],
          "type": "string"
        }
      },
      "type": "object"
    },
    "DataDisk": {
      "properties": {
        "Count": {
          "description": "磁盘块数，默认值4，最大15，最小1。",
          "maximum": 15,
          "type": "integer"
        },
        "Size": {
          "description": "磁盘大小，默认值80GB，最小60GB，最大2048GB，单位GB。",
          "maximum": 2048,
          "type": "integer"
        },
        "VolumeType": {
          "description": "磁盘类型。ESSD_PL0 ：极速型SSD_PL0。ESSD_PL1 ：极速型SSD_PL1。ESSD_PL2 ：极速型SSD_PL2。ESSD_PL3 ：极速型SSD_PL3。ESSD_FLEXPL ：极速型SSD_FlexPL。ULTRA_DISK ：高效云盘。PTSSD ：性能型SSD。SSD ：通用型SSD。EHDD ：高效云盘。ZENYA_SSD ：Zenya。LOCAL_HDD ：大数据型HDD。LOCAL_SSD ：本地SSD型。LOCAL_SSD_SRIOV ：本地SSD型SRIOV",
          "type": "string"
        }
      },
      "required": [
        "Count",
        "Size"
      ],
      "type": "object"
    },
    "EffectiveScope": {
      "properties": {
        "ComponentNames": {
          "description": "组件名列表，当EffectiveType=COMPONENT_NAME，必选。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "EffectiveType": {
          "description": "生效类型。CLUSTER，NODE_GROUP_NAME，NODE_GROUP_ID，NODE_GROUP_TYPE，NODE_NAME，NODE_ID，COMPONENT_NAME。",
          "enum": [
            "CLUSTER",
            "NODE_GROUP_NAME",
            "NODE_GROUP_ID",
            "NODE_GROUP_TYPE",
            "NODE_NAME",
            "NODE_ID",
            "COMPONENT_NAME"
          ],
          "type": "string"
        },
        "NodeGroupIds": {
          "description": "节点组ID列表，EffectiveType=NODE_GROUP_ID时，必选。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "NodeGroupNames": {
          "description": "节点组名称列表，EffectiveType=NODE_GROUP_NAME时，必选。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "NodeGroupTypes": {
          "description": "节点组类型列表，EffectiveType=NODE_GROUP_TYPE时，必选。目前包括MASTER、CORE、TASK。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "NodeIds": {
          "description": "节点ID列表，EffectiveType=NODE_ID时，必选。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "NodeNames": {
          "description": "节点名列表，EffectiveType=NODE_NAME时，必选。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        }
      },
      "type": "object"
    },
    "NodeAttribute": {
      "properties": {
        "EcsIamRole": {
          "description": "ECS实例角色。",
          "type": "string"
        },
        "ZoneId": {
          "description": "可用区ID。",
          "type": "string"
        }
      },
      "type": "object"
    },
    "NodeGroupAttribute": {
      "properties": {
        "Bandwidth": {
          "description": "公网带宽。默认值 8M。后续如果用户侧调整了，emr侧需要同步该信息。",
          "type": "integer"
        },
        "ChargeType": {
          "description": "节点组付费类型。为空时，复用集群的chargeType。Master、Core组必须复用集群维度的付费类型。当集群的chargeType为PRE时，task节点组的chargeType允许设置为POST；当集群的chargeType为POST时，节点组的chargeType默认为POST，节点组上的此参数设置无效。",
          "type": "string"
        },
        "CreateTime": {
          "description": "节点组创建时间。",
          "format": "int64",
          "type": "integer"
        },
        "DataDisks": {
          "description": "数据盘配置。当前单个节点组内只支持同规格的数据盘。即List的长度限制为1。",
          "insertionOrder": false,
          "items": {
            "$ref": "#/definitions/DataDisk"
          },
          "type": "array",
          "uniqueItems": true
        },
        "EcsInstanceTypes": {
          "description": "节点组的ecs机型列表。当前只支持设置1个机型。即List的长度限制为1。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "EcsKeyPairName": {
          "description": "ecs的密钥对名称。",
          "type": "string"
        },
        "EcsPassword": {
          "description": "Ecs root账号的密码。",
          "type": "string"
        },
        "LayoutComponentNames": {
          "description": "部署的组件名称列表。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "NodeCount": {
          "description": "节点组当前期望购买的节点数量。",
          "type": "integer"
        },
        "NodeGroupId": {
          "description": "节点组ID。",
          "type": "string"
        },
        "NodeGroupName": {
          "description": "长度为1~128个字符，不能以 http:： 和 https:： 开头。可以包含中文、英文、数字、下划线（_）、或者短划线（-）。",
          "maxLength": 128,
          "type": "string"
        },
        "NodeGroupState": {
          "description": "节点组状态。RUNNING,运行中。EXTENDING，扩容中。REDUCING，缩容中。DISK_EXTENDING，磁盘扩容中。MODIFYING，变配中",
          "type": "string"
        },
        "NodeGroupType": {
          "description": "节点组类型。",
          "type": "string"
        },
        "SubnetIds": {
          "description": "子网Id列表，目前只能传递一个参数，且各节点组的子网Id都是相同的。",
          "insertionOrder": false,
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "SystemDisk": {
          "$ref": "#/definitions/SystemDisk",
          "description": "系统盘配置。",
          "type": "object"
        },
        "WithPublicIp": {
          "description": "是否挂载公网ip。",
          "type": "boolean"
        },
        "ZoneId": {
          "description": "可用区ID。",
          "type": "string"
        }
      },
      "required": [
        "SubnetIds",
        "NodeGroupName",
        "NodeGroupType",
        "EcsInstanceTypes",
        "NodeCount",
        "SystemDisk",
        "DataDisks"
