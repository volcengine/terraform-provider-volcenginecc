      "maxLength": 64,
      "semantic": "projectName",
      "type": "string"
    },
    "ReadyTime": {
      "description": "集群创建完成时间。",
      "format": "int64",
      "type": "integer"
    },
    "ReleaseVersion": {
      "description": "集群版本。",
      "type": "string"
    },
    "SecurityGroupId": {
