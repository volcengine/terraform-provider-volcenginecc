{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/AllowListType",
    "/properties/ProjectName"
  ],
  "definitions": {
    "Instance": {
      "properties": {
        "InstanceId": {
          "description": "实例ID。",
          "type": "string"
        },
        "InstanceName": {
          "description": "实例名称。",
          "type": "string"
        },
        "VPC": {
          "description": "实例所属VPC ID。",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "vedbm访问白名单。",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/AssociatedInstances/*/InstanceId"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "vedbm:CreateAllowList",
        "vedbm:DescribeAllowLists",
        "vedbm:AssociateAllowList",
        "vedbm:DescribeAllowListDetail"
      ]
    },
    "delete": {
      "permissions": [
        "vedbm:DescribeAllowListDetail",
        "vedbm:DeleteAllowList",
        "vedbm:DisassociateAllowList"
      ]
    },
    "list": {
      "permissions": [
        "vedbm:DescribeAllowLists"
      ]
    },
    "read": {
      "permissions": [
        "vedbm:DescribeAllowLists",
        "vedbm:DescribeAllowListDetail"
      ]
    },
    "update": {
      "permissions": [
        "vedbm:DescribeAllowListDetail",
        "vedbm:ModifyAllowList",
        "vedbm:AssociateAllowList",
        "vedbm:DisassociateAllowList"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/AllowListId"
  ],
  "properties": {
    "AllowList": {
      "description": "IP 白名单，多个 IP 地址请以英文逗号（,）隔开，不可重复。",
      "type": "string"
    },
    "AllowListDesc": {
      "description": "白名单描述。",
      "semantic": "description",
      "type": "string"
    },
    "AllowListIPNum": {
      "description": "白名单内的 IP 地址（或地址段）总数。",
      "format": "int64",
      "type": "integer"
    },
    "AllowListId": {
      "description": "白名单的id。",
      "semantic": "resourceId",
      "type": "string"
    },
    "AllowListName": {
      "description": "白名单名称。",
      "semantic": "resourceName",
      "type": "string"
    },
    "AllowListType": {
      "description": "白名单内的IP地址类型，当前仅支持IPv4。",
      "type": "string"
    },
    "AssociatedInstanceNum": {
      "description": "白名单下绑定的实例总数",
      "format": "int64",
      "type": "integer"
    },
    "AssociatedInstances": {
      "description": "绑定的实例列表。",
      "insertionOrder": true,
      "items": {
        "$ref": "#/definitions/Instance"
      },
      "type": "array",
      "uniqueItems": true
    },
    "ModifyMode": {
      "description": "修改白名单的方式，支持设置为：Cover（默认）：使用 AllowList 参数中的值覆盖原白名单。Append：在原白名单中增加 AllowList 参数中输入的 IP 地址。Delete：在原白名单中删除 AllowList 参数中输入的 IP 地址。至少需要保留一个 IP 地址。",
      "type": "string"
    },
    "ProjectName": {
      "description": "白名单所属的项目名称，当该参数留空时，新建的白名单默认加入 default 项目",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AllowListId",
    "/properties/AllowListIPNum",
    "/properties/AssociatedInstanceNum",
    "/properties/AssociatedInstances/*/InstanceName",
    "/properties/AssociatedInstances/*/VPC"
  ],
  "required": [
    "AllowListName"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::VEDBM::AllowList",
  "writeOnlyProperties": [
    "/properties/ModifyMode"
  ]
}