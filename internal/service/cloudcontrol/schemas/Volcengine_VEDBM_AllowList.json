{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/AllowListType",
    "/properties/ProjectName"
  ],
  "definitions": {
    "Instance": {
      "properties": {
        "InstanceId": {
          "description": "Instance ID.",
          "type": "string"
        },
        "InstanceName": {
          "description": "Instance name.",
          "type": "string"
        },
        "VPC": {
          "description": "Instance VPC ID.",
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "description": "vedbm access allowlist.",
  "filterProperties": {
    "filterableProperties": [
      "/properties/ProjectName",
      "/properties/AssociatedInstances/*/InstanceId"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "vedbm:CreateAllowList",
        "vedbm:DescribeAllowLists",
        "vedbm:AssociateAllowList",
        "vedbm:DescribeAllowListDetail"
      ]
    },
    "delete": {
      "permissions": [
        "vedbm:DescribeAllowListDetail",
        "vedbm:DeleteAllowList",
        "vedbm:DisassociateAllowList"
      ]
    },
    "list": {
      "permissions": [
        "vedbm:DescribeAllowLists"
      ]
    },
    "read": {
      "permissions": [
        "vedbm:DescribeAllowLists",
        "vedbm:DescribeAllowListDetail"
      ]
    },
    "update": {
      "permissions": [
        "vedbm:DescribeAllowListDetail",
        "vedbm:ModifyAllowList",
        "vedbm:AssociateAllowList",
        "vedbm:DisassociateAllowList"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/AllowListId"
  ],
  "properties": {
    "AllowList": {
      "description": "IP allowlist. Separate multiple IP addresses with commas (,). Duplicate entries are not allowed.",
      "type": "string"
    },
    "AllowListDesc": {
      "description": "Allowlist description.",
      "semantic": "description",
      "type": "string"
    },
    "AllowListIPNum": {
      "description": "Total number of IP addresses (or address ranges) in the allowlist.",
      "format": "int64",
      "type": "integer"
    },
    "AllowListId": {
      "description": "Allowlist ID.",
      "semantic": "resourceId",
      "type": "string"
    },
    "AllowListName": {
      "description": "Allowlist name.",
      "semantic": "resourceName",
      "type": "string"
    },
    "AllowListType": {
      "description": "IP address type in the allowlist. Only IPv4 is currently supported.",
      "type": "string"
    },
    "AssociatedInstanceNum": {
      "description": "Total number of instances bound to the allowlist.",
      "format": "int64",
      "type": "integer"
    },
    "AssociatedInstances": {
      "description": "List of bound instances.",
      "insertionOrder": true,
      "items": {
        "$ref": "#/definitions/Instance"
      },
      "type": "array",
      "uniqueItems": true
    },
    "ModifyMode": {
      "description": "How to modify the allowlist. Supported settings: Cover (default): Overwrite the original allowlist with the values in the AllowList parameter. Append: Add IP addresses entered in the AllowList parameter to the original allowlist. Delete: Remove IP addresses entered in the AllowList parameter from the original allowlist. At least one IP address must remain.",
      "type": "string"
    },
    "ProjectName": {
      "description": "Project name associated with the allowlist. If left blank, the new allowlist will be added to the default project.",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/AllowListId",
    "/properties/AllowListIPNum",
    "/properties/AssociatedInstanceNum",
    "/properties/AssociatedInstances/*/InstanceName",
    "/properties/AssociatedInstances/*/VPC"
  ],
  "required": [
    "AllowListName"
  ],
  "tagging": {
    "taggable": false
  },
  "typeName": "Volcengine::VEDBM::AllowList",
  "writeOnlyProperties": [
    "/properties/ModifyMode"
  ]
}