{
  "additionalProperties": false,
  "createOnlyProperties": [
    "/properties/ChargeType",
    "/properties/FileSystemType",
    "/properties/ProtocolType",
    "/properties/SnapshotId",
    "/properties/StorageType",
    "/properties/ZoneId",
    "/properties/ProjectName"
  ],
  "definitions": {
    "CachePerformance": {
      "description": "Cache performance information",
      "properties": {
        "CacheBandwidth": {
          "description": "Provisioned bandwidth, used to increase file system bandwidth",
          "type": "integer"
        }
      },
      "type": "object"
    },
    "Capacity": {
      "description": "Capacity information",
      "properties": {
        "Total": {
          "description": "Total available file system capacity, in GiB",
          "type": "number"
        },
        "Used": {
          "description": "Used file system capacity, in MiB",
          "type": "number"
        }
      },
      "required": [
        "Total"
      ],
      "type": "object"
    },
    "Tag": {
      "description": "Resource tags",
      "properties": {
        "Key": {
          "description": "Tag key",
          "type": "string"
        },
        "Type": {
          "description": "Tag type",
          "type": "string"
        },
        "Value": {
          "description": "Tag value",
          "type": "string"
        }
      },
      "required": [
        "Key"
      ],
      "type": "object"
    }
  },
  "description": "The file system provides file storage services through the standard NFS protocol for remote network file access. After creating a mount point in the management console, you can access the file system on your client as needed using the standard POSIX interface",
  "filterProperties": {
    "filterableProperties": [
      "/properties/FileSystemId",
      "/properties/FileSystemType",
      "/properties/ProjectName",
      "/properties/Status",
      "/properties/FileSystemName",
      "/properties/ZoneId",
      "/properties/ProtocolType",
      "/properties/StorageType",
      "/properties/ChargeType",
      "/properties/Tags/*/Key",
      "/properties/Tags/*/Value"
    ]
  },
  "handlers": {
    "create": {
      "permissions": [
        "FileNAS:DescribeFileSystems",
        "FileNAS:CreateFileSystem"
      ]
    },
    "delete": {
      "permissions": [
        "FileNAS:DescribeFileSystems",
        "FileNAS:DeleteFileSystem"
      ]
    },
    "list": {
      "permissions": [
        "FileNAS:DescribeFileSystems"
      ]
    },
    "read": {
      "permissions": [
        "FileNAS:DescribeFileSystems"
      ]
    },
    "update": {
      "permissions": [
        "FileNAS:DescribeFileSystems",
        "FileNAS:ExpandFileSystem",
        "FileNAS:ModifyFileSystemSpec",
        "FileNAS:UpdateFileSystem"
      ]
    }
  },
  "primaryIdentifier": [
    "/properties/FileSystemId"
  ],
  "properties": {
    "CachePerformance": {
      "$ref": "#/definitions/CachePerformance",
      "description": "Cache performance information",
      "type": "object"
    },
    "Capacity": {
      "$ref": "#/definitions/Capacity",
      "description": "File system capacity",
      "type": "object"
    },
    "ChargeType": {
      "description": "Billing type. Value: PayAsYouGo, indicates pay-as-you-go billing",
      "type": "string"
    },
    "CreateTime": {
      "description": "Creation time",
      "semantic": "createdTime",
      "type": "string"
    },
    "Description": {
      "description": "Description",
      "semantic": "description",
      "type": "string"
    },
    "FileSystemId": {
      "description": "File system ID",
      "semantic": "resourceId",
      "type": "string"
    },
    "FileSystemName": {
      "description": "File system name",
      "semantic": "resourceName",
      "type": "string"
    },
    "FileSystemType": {
      "description": "File system type. Possible values: Extreme: NAS Extreme type; Capacity: NAS Capacity type; Cache: NAS Cache type",
      "enum": [
        "Extreme",
        "Capacity",
        "Cache"
      ],
      "type": "string"
    },
    "ProjectName": {
      "description": "Project, default value is the Default project",
      "semantic": "projectName",
      "type": "string"
    },
    "ProtocolType": {
      "description": "File system protocol type. Value: NFS, indicates NFS protocol, commonly used for Linux clients",
      "type": "string"
    },
    "SnapshotCount": {
      "description": "Number of snapshots",
      "type": "integer"
    },
    "SnapshotId": {
      "description": "Snapshot ID used at creation. If this parameter is provided, the file system will be created from the snapshot",
      "type": "string"
    },
    "Status": {
      "description": "File system status. Possible values: Unknown: Status unknown. Running: File system running. Creating: File system being created. Expanding: File system being upgraded. Error: File system error. Deleting: File system being deleted. DeleteError: File system deletion failed. Deleted: File system deleted. Stopped: File system stopped.",
      "enum": [
        "Unknown",
        "Running",
        "Creating",
        "Expanding",
        "Error",
        "Deleting",
        "DeleteError",
        "Deleted",
        "Stopped"
      ],
      "semantic": "status",
      "type": "string"
    },
    "StorageType": {
      "description": "Storage type. Value: Standard, indicates standard type",
      "type": "string"
    },
    "Tags": {
      "description": "File system tag information",
      "insertionOrder": false,
      "items": {
        "$ref": "#/definitions/Tag"
      },
      "semantic": "tags",
      "type": "array",
      "uniqueItems": true
    },
    "UpdateTime": {
      "description": "Update time",
      "semantic": "updatedTime",
      "type": "string"
    },
    "ZoneId": {
      "description": "Availability Zone ID",
      "type": "string"
    },
    "ZoneName": {
      "description": "Availability Zone name",
      "type": "string"
    }
  },
  "readOnlyProperties": [
    "/properties/CreateTime",
    "/properties/FileSystemId",
    "/properties/SnapshotCount",
    "/properties/Status",
    "/properties/UpdateTime",
    "/properties/ZoneName",
    "/properties/Capacity/Used"
  ],
  "required": [
    "ZoneId",
    "FileSystemName",
    "ChargeType",
    "FileSystemType",
    "ProtocolType"
  ],
  "tagging": {
    "tagOnCreate": true,
    "tagUpdatable": true,
    "taggable": true
  },
  "typeName": "Volcengine::FileNAS::Instance",
  "writeOnlyProperties": [
    "/properties/SnapshotId"
  ]
}